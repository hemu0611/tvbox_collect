                                var newLoad21 = clamp(get(vars, '生理.免疫負荷') + 0.3 * delta, 0, 100);
                                set(vars, '生理.免疫負荷', newLoad21);
                                logChange('持續傷害', '有點髒：免疫負荷 +' + (0.3 * delta).toFixed(2) + ' → ' + newLoad21.toFixed(2));
                                fixCount++;
                                break;
                            case '污穢不堪':
                                var newLoad22 = clamp(get(vars, '生理.免疫負荷') + 0.5 * delta, 0, 100);
                                set(vars, '生理.免疫負荷', newLoad22);
                                logChange('持續傷害', '污穢不堪：免疫負荷 +' + (0.5 * delta).toFixed(2) + ' → ' + newLoad22.toFixed(2));
                                fixCount++;
                                break;
                        }
                    }
                }
            }
        }
        
        // 計算最終生命上限和免疫力
        var baseHpMax = 4 * end, immunity = end;
        
        if (statuses.氮平衡 && statuses.氮平衡.name === '嚴重負氮平衡') {
            baseHpMax -= 10;
            immunity -= 10;
        }
        
        if (statuses.維生素) {
            switch(statuses.維生素.name) {
                case '維生素充足': immunity += 5; break;
                case '維生素缺乏': immunity -= 5; break;
                case '維生素嚴重缺乏': immunity -= 10; break;
            }
        }
        
        if (statuses.體溫) {
            switch(statuses.體溫.name) {
                case '發燒': immunity += 5; break;
                case '高熱': immunity += 10; break;
            }
        }
        var oldStatsForImmunity = (statusCache && statusCache.statuses) ? statusCache.statuses : {};
 
        if (statuses.疲勞 && statuses.疲勞.name === '相當疲勞' && (!oldStatsForImmunity.疲勞 || oldStatsForImmunity.疲勞.name !== '相當疲勞')) immunity -= 2;
        if (statuses.疲勞 && statuses.疲勞.name === '筋疲力盡' && (!oldStatsForImmunity.疲勞 || oldStatsForImmunity.疲勞.name !== '筋疲力盡')) immunity -= 4;
        
        var spMax = 4 * will;
        var spCur2 = get(vars, '精神.當前精神值');
        if (spCur2 > spMax) {
            set(vars, '精神.當前精神值', spMax);
            logChange('邊界修正', '當前精神值 ' + spCur2 + ' → ' + spMax);
            fixCount++;
        }
        
        var immLoadCurr = get(vars, '生理.免疫負荷');
        if (immLoadCurr > 100) {
            set(vars, '生理.免疫負荷', 100);
            logChange('邊界修正', '免疫負荷 ' + immLoadCurr + ' → 100');
            fixCount++;
        } else if (immLoadCurr < 0) {
            set(vars, '生理.免疫負荷', 0);
            logChange('邊界修正', '免疫負荷 ' + immLoadCurr + ' → 0');
            fixCount++;
        }
        
        var curImmunity = get(vars, '狀態.免疫力');
        var finalImm = clamp(immunity, 0, 100);
        if (curImmunity !== finalImm) {
            set(vars, '狀態.免疫力', finalImm);
            logChange('免疫力修正', curImmunity + ' → ' + finalImm);
            fixCount++;
        }
        
        statusCache = { time: cur, statuses: statuses };
    }

        // ======================== 清理已完結的劇情演出 ========================
function cleanupCompletedPerformances(vars) {
    var comps = get(vars, '同伴');
    if (!_.isPlainObject(comps)) return;
    
    for (var name in comps) {
        if (name.startsWith('$')) continue;
        
        var performances = get(vars, '同伴.' + name + '.劇情演出');
        if (!Array.isArray(performances) || performances.length === 0) continue;
        
        // 收集需要刪除的主題
        var themesToDelete = {};
        
        // 第一遍：分析每個主題的狀態
        for (var i = 0; i < performances.length; i++) {
            var perf = performances[i];
            if (typeof perf !== 'string') continue;
            
            // 解析格式：事件-主題-序號-狀態:描述
            var match = perf.match(/^事件-([^-]+)-(\d+)-(.+?):(.+)$/);
            if (!match) continue;
            
            var theme = match[1];
            var seq = parseInt(match[2]);
            var status = match[3];
            var desc = match[4];
            
            if (!themesToDelete[theme]) {
                themesToDelete[theme] = {
                    maxSeq: 0,
                    hasCompleted: false,
                    indices: []
                };
            }
            
            themesToDelete[theme].indices.push(i);
            if (seq > themesToDelete[theme].maxSeq) {
                themesToDelete[theme].maxSeq = seq;
            }
            if (status === '已完成') {
                themesToDelete[theme].hasCompleted = true;
            }
        }
        
        // 第二遍：從後往前刪除（避免索引錯亂）
        var indicesToRemove = [];
        for (var theme in themesToDelete) {
            var info = themesToDelete[theme];
            
            // 規則：當序號達到 5 且最後一個事件已完成時，刪除整個主題
            if (info.maxSeq >= 5 && info.hasCompleted) {
                indicesToRemove.push(...info.indices);
                logChange('劇情演出清理', name + ' 主題「' + theme + '」序號已達 ' + info.maxSeq + '，已完結，刪除 ' + info.indices.length + ' 條');
                fixCount++;
            }
        }
        
        // 從後往前刪除（保持索引有效）
        if (indicesToRemove.length > 0) {
            indicesToRemove.sort((a, b) => b - a);
            for (var i = 0; i < indicesToRemove.length; i++) {
                performances.splice(indicesToRemove[i], 1);
            }
            set(vars, '同伴.' + name + '.劇情演出', performances);
        }
    }
}

    // ======================== 任務和商店處理 ========================
function processTasksAndShop(vars) {
    function updateTaskCompletion(tp) {
        var task = get(vars, tp);
        if (!_.isPlainObject(task) || !task.狀態) return;
        var changed = false;
        
        var baseReqs = get(task, '任務要求');
        if (_.isPlainObject(baseReqs)) {
            var allDone = true;
            for (var k in baseReqs) {
                if (k.startsWith('$')) continue;
                var req = baseReqs[k],
                    newReq = checkRequirement(req);
                if (newReq !== req) {
                    set(vars, tp + '.任務要求.' + k, newReq);
                    changed = true;
                }
                if (!newReq.已完成) allDone = false;
            }
            var curDone = get(task, '完成情況.基礎要求完成');
            if (allDone !== curDone) {
                set(vars, tp + '.完成情況.基礎要求完成', allDone);
                changed = true;
            }
        }
        
        var advReqs = get(task, '進階目標');
        if (_.isPlainObject(advReqs)) {
            var allDone = true;
            for (var k in advReqs) {
                if (k.startsWith('$')) continue;
                var req = advReqs[k],
                    newReq = checkRequirement(req);
                if (newReq !== req) {
                    set(vars, tp + '.進階目標.' + k, newReq);
                    changed = true;
                }
                if (!newReq.已完成) allDone = false;
            }
            var curDone = get(task, '完成情況.進階目標完成');
            if (allDone !== curDone) {
                set(vars, tp + '.完成情況.進階目標完成', allDone);
                changed = true;
            }
        }
        
        return changed;
    }

    function updateTaskStatus(tp, type) {
        var task = get(vars, tp);
        if (!_.isPlainObject(task) || !task.狀態) return;
        var status = get(task, '狀態'),
            baseDone = get(task, '完成情況.基礎要求完成', false),
            advDone = get(task, '完成情況.進階目標完成', false),
            hasAdv = _.isPlainObject(get(task, '進階目標')) && 
                     Object.keys(get(task, '進階目標')).filter(function(k) { return !k.startsWith('$'); }).length > 0,
            endTimeStr = get(task, '結束時間', ''),
            curTime = getCurrentTime(vars);
        var correct = status,
            endTime = endTimeStr ? parseFullTime(endTimeStr) : null,
            expired = endTime && curTime && curTime.total >= endTime.total;
        
        if (expired) {
            if (baseDone) {
                correct = '待結算';
                if (hasAdv && !advDone) {
                    var s = get(task, '結算狀態') || { 基礎獎勵已發放: false, 進階獎勵已發放: false, 失敗懲罰已發放: false };
                    if (!s.進階獎勵已發放) set(vars, tp + '.結算狀態', { ...s, 進階獎勵已發放: true });
                }
            } else {
                if (type === '緊急') {
                    correct = '已失敗';
                    var s = get(task, '結算狀態') || { 基礎獎勵已發放: false, 進階獎勵已發放: false, 失敗懲罰已發放: false };
                    if (s.失敗懲罰已發放 === undefined || s.失敗懲罰已發放 === false) {
                        set(vars, tp + '.結算狀態', { ...s, 失敗懲罰已發放: false });
                    }
                } else {
                    correct = '已放棄';
                }
            }
        } else {
            if (!baseDone) correct = '進行中';
            else if (hasAdv && !advDone) correct = '進階中';
            else correct = '待結算';
        }
        
        if (status !== correct) {
            set(vars, tp + '.狀態', correct);
            logChange('任務狀態修正', tp + ' ' + status + ' → ' + correct);
        }
    }
    
    // ========== 主線、支線、日常、緊急、背德（統一處理） ==========
    // 🔴 加入「背德」
    var types = ['主線', '支線', '日常', '緊急', '背德'];
    for (var i = 0; i < types.length; i++) {
        var t = types[i], p = '任務.' + t;
        var task = get(vars, p);
        if (_.isPlainObject(task) && task.狀態) {
            updateTaskCompletion(p);
            updateTaskStatus(p, t);
        }
    }
    
    // ========== 羈絆任務（保持原本的獨立迴圈，不做任何修改） ==========
    var bond = get(vars, '任務.羈絆');
    if (_.isPlainObject(bond)) {
        for (var n in bond) {
            if (n.startsWith('$')) continue;
            var p = '任務.羈絆.' + n;
            var task = bond[n];
            if (_.isPlainObject(task) && task.狀態) {
                updateTaskCompletion(p);
                updateTaskStatus(p, '羈絆');
            }
        }
    }
    
    // ========== 清理 ==========
    function cleanup() {
        // 清理主類型任務（加入「背德」）
        var types = ['主線', '支線', '日常', '緊急', '背德'];
        for (var i = 0; i < types.length; i++) {
            var t = types[i], p = '任務.' + t;
            var task = get(vars, p);
            if (!_.isPlainObject(task) || _.isEmpty(task)) continue;
            var baseReward = get(task, '結算狀態.基礎獎勵已發放', false);
            var advReward = get(task, '結算狀態.進階獎勵已發放', false);
            var hasAdv = _.isPlainObject(get(task, '進階目標')) && 
                         Object.keys(get(task, '進階目標')).filter(function(k) { return !k.startsWith('$'); }).length > 0;
            var allDone = baseReward && (!hasAdv || advReward);
            if (allDone) {
                _.set(vars, p, {});
                logChange('任務清理', p + ' 設爲空對象');
                continue;
            }
            var status = get(task, '狀態');
            if (status === '待結算' && baseReward && (!hasAdv || advReward)) {
                _.set(vars, p, {});
                logChange('任務清理', p + ' 設爲空對象');
            } else if (status === '已放棄') {
                _.set(vars, p, {});
                logChange('任務清理', p + ' 設爲空對象');
            } else if (status === '已失敗' && get(task, '結算狀態.失敗懲罰已發放', false)) {
                _.set(vars, p, {});
                logChange('任務清理', p + ' 設爲空對象');
            }
        }
        
        // 羈絆任務清理（保持原本不變）
        var bond2 = get(vars, '任務.羈絆');
        if (_.isPlainObject(bond2)) {
            for (var n in bond2) {
                if (n.startsWith('$')) continue;
                var p = '任務.羈絆.' + n;
                var task = bond2[n];
                if (!_.isPlainObject(task) || _.isEmpty(task)) continue;
                var baseReward = get(task, '結算狀態.基礎獎勵已發放', false);
                var advReward = get(task, '結算狀態.進階獎勵已發放', false);
                var hasAdv = _.isPlainObject(get(task, '進階目標')) && 
                             Object.keys(get(task, '進階目標')).filter(function(k) { return !k.startsWith('$'); }).length > 0;
                var allDone = baseReward && (!hasAdv || advReward);
                if (allDone) {
                    _.set(vars, p, {});
                    logChange('羈絆任務清理', p + ' 設爲空對象');
                    continue;
                }
                var status = get(task, '狀態');
                if (status === '待結算' && baseReward && (!hasAdv || advReward)) {
                    _.set(vars, p, {});
                    logChange('羈絆任務清理', p + ' 設爲空對象');
                } else if (status === '已放棄') {
                    _.set(vars, p, {});
                    logChange('羈絆任務清理', p + ' 設爲空對象');
                }
            }
        }
    }
    
    cleanup();
}

// ======================== 同伴生效效果（改寫版 - 適用你的路徑） ========================
function processCompanionStatusEffects(vars) {
  var comps = get(vars, '同伴');
  if (!_.isPlainObject(comps)) return;
  
  var cur = getCurrentTime(vars);
  if (!cur) return;
  
  // 獲取主角的維生素和氮平衡（同伴會受影響）
  var playerVit = int(get(vars, '生理.維生素')) || 0;
  var playerNitro = int(get(vars, '生理.氮平衡')) || 0;
  
  for (var n in comps) {
    if (n.startsWith('$')) continue;
    var base = '同伴.' + n;
    
    // ========== 🔴 1. 初始化 effects 和 statuses（每個同伴獨立） ==========
    var effects = {};
    var statuses = {};
    
    // ========== 🔴 2. 定義 add 函數（在使用之前） ==========
    function add(k, name, desc) {
      effects[k] = { 狀態: name, 效果: desc };
      statuses[k] = { name: name };
    }
    
    // ========== 3. 確保生效效果路徑存在 ==========
    var effPath = base + '.狀態.生效效果';
    var curEff = get(vars, effPath);
    if (!_.isPlainObject(curEff)) {
        set(vars, effPath, {});
        curEff = {};
        debugLog('初始化 ' + n + ' 的生效效果路徑');
    }
    
    // ========== 4. 讀取數據 ==========
    var water = int(get(vars, base + '.生理.水分')) || 0;
    var full = int(get(vars, base + '.生理.飽腹感')) || 0;
    var excretion = int(get(vars, base + '.生理.排泄欲')) || 0;
    
    var stress = int(get(vars, base + '.精神.壓力')) || 0;
    var sleepVal = int(get(vars, base + '.精神.睡眠')) || 0;
    
    var fatigue = int(get(vars, base + '.狀態.疲勞')) || 0;
    var cleanVal = int(get(vars, base + '.狀態.清潔')) || 0;
    
    var endLv = int(get(vars, base + '.屬性.耐力.等級')) || 20;
    var maxFat = 4 * endLv;
    var fatPerc = maxFat > 0 ? fatigue / maxFat * 100 : 0;
    
    // 生命/精神值（用於持續傷害）
    var hpCur = int(get(vars, base + '.生理.當前生命值')) || 100;
    var hpMaxV = int(get(vars, base + '.生理.生命值上限')) || 100;
    var spCur2 = int(get(vars, base + '.精神.當前精神值')) || 100;
    var spMaxV = int(get(vars, base + '.精神.精神值上限')) || 100;
    
    // ========== 5. 生理週期計算 ==========
    var menses = int(get(vars, base + '.生理狀態.月經週期')) || 14;
    var pregnant = get(vars, base + '.生理狀態.懷孕狀態');
    var isPregnant = (pregnant && pregnant !== '未懷孕' && pregnant !== '流產');
    var preDays = isPregnant ? (get(vars, base + '.生理狀態.懷孕天數') || 0) : 0;
    
    var cyclePhase = '';
    var phaseDesc = '';
    if (isPregnant) {
