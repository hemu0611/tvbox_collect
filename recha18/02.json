    if (water > 90) add('水分', '水分充足', '身體水分充足，精神飽滿。所有與耐力相關的檢定獲得+5背景加值。');
    else if (water > 70) add('水分', '狀態正常', '沒什麼特別的感覺。');
    else if (water > 50) add('水分', '輕微口渴', '喉嚨有點幹，下意識想找水喝，注意力有點不集中。所有智力、感知相關檢定受到-2減值。');
    else if (water > 30) add('水分', '明顯口渴', '口乾舌燥，感覺有些煩躁，身體在強烈要求補水。所有重體力相關檢定（如力量、耐力）受到-5減值。');
    else if (water > 10) add('水分', '輕度脫水', '嘴脣乾裂，頭暈乏力，身體因缺水而變得遲鈍。所有重體力相關檢定受到-10減值。');
    else if (water > 0) add('水分', '嚴重脫水', '嚴重缺水，視野開始模糊，身體機能受到明顯影響，必須立刻補充水分。所有重體力相關檢定受到-15減值。');
    else add('水分', '瀕死：脫水', '身體因嚴重缺水而瀕臨崩潰。');
    
    // ========== 8. 飽腹感 ==========
    if (full > 95) add('飽腹感', '過飽', '吃撐了，行動有點不方便。所有敏捷和耐力相關檢定受到-5減值。');
    else if (full > 85) add('飽腹感', '飽足', '吃飽喝足，感覺充滿能量，體力充沛，疲勞感不易累積。');
    else if (full > 60) add('飽腹感', '狀態正常', '沒什麼特別的感覺。');
    else if (full > 30) add('飽腹感', '輕微飢餓', '肚子有點空，開始期待下一頓飯。');
    else if (full > 10) add('飽腹感', '明顯飢餓', '肚子在咕咕叫，有點想吃東西了，注意力難以集中。所有屬性檢定受到-5減值。');
    else if (full > 0) add('飽腹感', '極度飢餓', '餓得前胸貼後背，身體因爲缺乏能量而感到虛弱，必須儘快進食。所有屬性檢定受到-15減值。');
    else add('飽腹感', '虛脫', '身體因能量儲備完全耗盡而極度虛弱，各項機能開始下降，身體正在消耗自身以維持生命。必須立即進食以阻止進一步惡化。');
    
    // ========== 9. 疲勞 ==========
    if (fatPerc < 10) add('疲勞', '精力十足', '渾身是勁，感覺還能再戰三百回合。所有與力量和敏捷相關檢定獲得+5背景加值。');
    else if (fatPerc <= 30) add('疲勞', '狀態正常', '身體狀態良好，沒什麼特別感覺。');
    else if (fatPerc <= 50) add('疲勞', '微微出汗', '身體開始發熱，呼吸稍微加快，但還遠未到累的時候。');
    else if (fatPerc <= 70) add('疲勞', '有些疲憊', '肌肉微微發酸，呼吸比平時稍重，是時候考慮歇一歇了。所有重體力相關檢定受到-5減值。');
    else if (fatPerc <= 90) add('疲勞', '相當疲勞', '身體變得沉重，每一下動作都需要更多力氣，疲倦感十分明顯。所有重體力相關檢定受到-10減值。');
    else add('疲勞', '筋疲力盡', '身體非常沉重，每一下動作都變得吃力，只想找個地方坐下來喘口氣。所有重體力相關檢定受到-15減值。');
    
    // ========== 10. 壓力 ==========
    if (stress < 10) add('壓力', '心神沉靜', '思維清晰，內心平靜。意志、智力檢定獲得+5加值。');
    else if (stress < 50) add('壓力', '狀態正常', '無特殊效果。');
    else if (stress < 80) add('壓力', '高度焦慮', '壓力極大，內心充滿焦慮和不安。所有檢定受到-5減值。');
    else if (stress < 100) add('壓力', '不堪重負', '巨大的壓力使她瀕臨崩潰邊緣。所有檢定受到-10減值。');
    else add('壓力', '精神崩潰', '精神防線徹底崩潰，陷入恐慌、偏執或絕望狀態。');
    
    // ========== 11. 睡眠 ==========
    if (sleepVal > 90) add('睡眠', '精力充沛', '充足的睡眠讓她恢復了所有精力。疲勞恢復速度加倍，精神屬性和技能相關檢定+5。');
    else if (sleepVal > 60) add('睡眠', '狀態正常', '無特殊效果。');
    else if (sleepVal > 30) add('睡眠', '疲倦', '開始感到身體和精神的疲勞。所有屬性檢定受到-5減值。');
    else if (sleepVal > 0) add('睡眠', '非常疲憊', '嚴重缺乏睡眠，眼皮沉重，反應遲鈍。所有屬性檢定受到-15減值。');
    else add('睡眠', '精疲力竭', '身體達到極限，隨時可能因過度疲勞而昏倒。');
    
    // ========== 12. 清潔 ==========
    if (cleanVal > 90) add('清潔', '乾淨整潔', '全身清爽，心情愉悅。所有與意志、智力相關的檢定獲得+2背景加值。');
    else if (cleanVal > 40) add('清潔', '狀態正常', '無特殊效果。');
    else if (cleanVal > 10) add('清潔', '有點髒', '身上有污垢或異味，讓人不適。');
    else add('清潔', '污穢不堪', '全身骯髒，散發惡臭，大大增加感染疾病的風險。');
    
    // ========== 13. 維生素（受主角影響） ==========
    if (playerVit > 80) add('維生素', '維生素充足', '維生素充足。');
    else if (playerVit > 30) add('維生素', '狀態正常', '無特殊效果。');
    else if (playerVit > 0) add('維生素', '維生素缺乏', '身體出現多種不良反應，更快疲勞等。');
    else add('維生素', '維生素嚴重缺乏', '出現壞血病、夜盲症等嚴重疾病。');
    
    // ========== 14. 氮平衡（受主角影響） ==========
    if (playerNitro >= 75) add('氮平衡', '正氮平衡', '蛋白質充足，力量相關檢定效果增強，更快從疲勞恢復。');
    else if (playerNitro >= 0) add('氮平衡', '狀態正常', '無特殊效果。');
    else if (playerNitro >= -50) add('氮平衡', '負氮平衡', '蛋白質不足，肌肉分解流失。力量下降，免疫力下降，傷口難以癒合，更難恢復耐力。');
    else add('氮平衡', '嚴重負氮平衡', '蛋白質嚴重缺乏，身體機能大幅受損。');
    
    // ========== 15. 排泄需求（從單一排泄欲轉換） ==========
    var pee = excretion;
    var poo = excretion;
    
    var peeStage = '', peeDesc = '', pooStage = '', pooDesc = '';
    if (pee < 20) { peeStage = '狀態正常'; peeDesc = '暫無尿意'; }
    else if (pee < 40) { peeStage = '輕微尿意'; peeDesc = '開始有排尿的感覺，尚可忍受'; }
    else if (pee < 60) { peeStage = '尿急'; peeDesc = '排尿需求變得強烈，注意力輕微分散（智力、感知檢定-2）'; }
    else if (pee < 80) { peeStage = '憋不住'; peeDesc = '排尿需求非常緊迫，難以集中精神（智力、感知檢定-5）'; }
    else { peeStage = '快要失禁'; peeDesc = '隨時可能失禁，必須立即排尿（智力、感知檢定-10）'; }
    
    if (poo < 20) { pooStage = '狀態正常'; pooDesc = '暫無便意'; }
    else if (poo < 40) { pooStage = '輕微便意'; pooDesc = '開始有排便的感覺，尚可忍受'; }
    else if (poo < 60) { pooStage = '急需排便'; pooDesc = '排便需求強烈，腹部不適（智力、感知檢定-2）'; }
    else if (poo < 80) { pooStage = '忍不住'; pooDesc = '排便需求非常緊迫，必須立即解決（智力、感知檢定-5）'; }
    else { pooStage = '即將失禁'; pooDesc = '隨時可能失禁，必須立即排便（智力、感知檢定-10）'; }
    
    var excreteDesc = '';
    if (peeStage === '狀態正常' && pooStage === '狀態正常') {
      excreteDesc = '暫無排泄需求，身體感覺輕鬆。';
    } else {
      excreteDesc = peeDesc + '。同時，' + pooDesc;
    }
    var dominant = (pee > poo) ? peeStage : pooStage;
    add('排泄需求', dominant, excreteDesc);
    
    // ========== 16. 寫入生效效果 ==========
    var curEff = get(vars, base + '.狀態.生效效果') || {};
    
    // 更新或新增效果
    for (var k in effects) {
      var newEff = effects[k];
      var old = curEff[k];
      if (!old || old.狀態 !== newEff.狀態 || old.效果 !== newEff.效果) {
        set(vars, base + '.狀態.生效效果.' + k, newEff);
        debugLog('同伴生效效果更新', n + ': ' + k + ' → ' + newEff.狀態);
        fixCount++;
      }
    }
    
    // 清理過期的效果（保留懷孕和生理週期，因為已單獨處理）
    for (var k in curEff) {
      if (k === '懷孕' || k === '生理週期') continue;
      if (!effects[k] && curEff[k] !== undefined) {
        _.unset(vars, base + '.狀態.生效效果.' + k);
        debugLog('同伴生效效果移除', n + ': ' + k);
        fixCount++;
      }
    }
    
    // ========== 17. 持續傷害計算 ==========
    if (statusCache && cur) {
      var delta = 0;
      try {
        var prevT = statusCache.time;
        if (prevT && prevT.total) delta = (cur.total - prevT.total) / 60;
      } catch(e) {}
      
      if (delta > 0) {
        var damageStates = [
          '明顯口渴', '輕度脫水', '嚴重脫水', '過飽',
          '明顯飢餓', '極度飢餓', '虛脫', '相當疲勞', '筋疲力盡',
          '高度焦慮', '不堪重負', '有點髒', '污穢不堪',
          '維生素缺乏', '維生素嚴重缺乏', '負氮平衡', '嚴重負氮平衡'
        ];
        
        for (var k in statuses) {
          var s = statuses[k];
          if (s && damageStates.includes(s.name)) {
            debugLog('[同伴持續傷害] ' + n + ' ' + s.name + ' 時間差：' + delta.toFixed(2) + '小時');
            
            switch (s.name) {
              case '明顯口渴':
                set(vars, base + '.精神.當前精神值', Math.round(clamp(spCur2 - 0.5 * delta, 0, spMaxV)));
                break;
              case '輕度脫水':
                set(vars, base + '.生理.當前生命值', Math.round(clamp(hpCur - 0.5 * delta, 0, hpMaxV)));
                set(vars, base + '.精神.當前精神值', Math.round(clamp(spCur2 - 0.5 * delta, 0, spMaxV)));
                break;
              case '嚴重脫水':
                set(vars, base + '.生理.當前生命值', Math.round(clamp(hpCur - 1 * delta, 0, hpMaxV)));
                set(vars, base + '.精神.當前精神值', Math.round(clamp(spCur2 - 1 * delta, 0, spMaxV)));
                break;
              case '過飽':
                set(vars, base + '.狀態.疲勞', Math.round(clamp(fatigue + 1 * delta, 0, maxFat)));
                break;
              case '明顯飢餓':
                set(vars, base + '.精神.當前精神值', Math.round(clamp(spCur2 - 0.5 * delta, 0, spMaxV)));
                break;
              case '極度飢餓':
                set(vars, base + '.生理.當前生命值', Math.round(clamp(hpCur - 0.5 * delta, 0, hpMaxV)));
                set(vars, base + '.精神.當前精神值', Math.round(clamp(spCur2 - 1 * delta, 0, spMaxV)));
                break;
              case '虛脫':
                set(vars, base + '.生理.當前生命值', Math.round(clamp(hpCur - 1 * delta, 0, hpMaxV)));
                set(vars, base + '.精神.當前精神值', Math.round(clamp(spCur2 - 2 * delta, 0, spMaxV)));
                break;
              case '高度焦慮':
                set(vars, base + '.精神.當前精神值', Math.round(clamp(spCur2 - 0.3 * delta, 0, spMaxV)));
                break;
              case '不堪重負':
                set(vars, base + '.精神.當前精神值', Math.round(clamp(spCur2 - 0.5 * delta, 0, spMaxV)));
                break;
              case '有點髒':
                set(vars, base + '.精神.睡眠', Math.round(clamp(sleepVal - 0.2 * delta, 0, 100)));
                break;
              case '污穢不堪':
                set(vars, base + '.精神.睡眠', Math.round(clamp(sleepVal - 0.3 * delta, 0, 100)));
                set(vars, base + '.狀態.疲勞', Math.round(clamp(fatigue + 0.3 * delta, 0, maxFat)));
                break;
              case '維生素缺乏':
                set(vars, base + '.狀態.疲勞', Math.round(clamp(fatigue + 0.3 * delta, 0, maxFat)));
                break;
              case '維生素嚴重缺乏':
                set(vars, base + '.狀態.疲勞', Math.round(clamp(fatigue + 0.5 * delta, 0, maxFat)));
                set(vars, base + '.生理.當前生命值', Math.round(clamp(hpCur - 0.3 * delta, 0, hpMaxV)));
                break;
              case '負氮平衡':
                set(vars, base + '.狀態.疲勞', Math.round(clamp(fatigue + 0.2 * delta, 0, maxFat)));
                break;
              case '嚴重負氮平衡':
                set(vars, base + '.生理.當前生命值', Math.round(clamp(hpCur - 0.5 * delta, 0, hpMaxV)));
                set(vars, base + '.狀態.疲勞', Math.round(clamp(fatigue + 0.5 * delta, 0, maxFat)));
                break;
            }
          }
        }
      }
    }
  }
}

// ==================== 流產後續清理 ====================
function processMiscarriageCleanup(vars) {
    var companions = get(vars, '同伴');
    if (!_.isPlainObject(companions)) return;
    
    var currentDay = get(vars, '系統.經過天數') || 0;
    
    for (var name in companions) {
        if (name.startsWith('$')) continue;
        
        var pending = get(vars, '同伴.' + name + '.生理狀態.流產待處理');
        if (pending !== true) continue;
        
        keyLog('💔 檢測到 ' + name + ' 流產待處理，執行後續清理...');
        
        // 0. 🔴 新增：月經週期重置（雙重保障）
        set(vars, '同伴.' + name + '.生理狀態.月經週期', 1);
        keyLog('🔄 ' + name + ' 月經週期重置為 1');
        
        // 1. 清除未出生的子嗣（母親 = name 且沒有出生日期）
        var children = get(vars, '子嗣');
        if (_.isPlainObject(children)) {
            var toRemove = [];
            for (var childName in children) {
                if (childName.startsWith('$')) continue;
                var child = children[childName];
                if (child.母親 === name && !child.出生日期) {
                    toRemove.push(childName);
                }
            }
            for (var i = 0; i < toRemove.length; i++) {
                _.unset(vars, '子嗣.' + toRemove[i]);
                keyLog('🗑️ 清除未出生子嗣: ' + toRemove[i]);
            }
        }
        
        // 2. 觸發劇情演出（如果有）
        var performances = get(vars, '同伴.' + name + '.劇情演出') || [];
        var hasEvent = false;
        for (var i = 0; i < performances.length; i++) {
            if (typeof performances[i] === 'string' && performances[i].indexOf('事件-流產-') !== -1) {
                hasEvent = true;
                break;
            }
        }
        if (!hasEvent) {
            performances.push('事件-流產-1-待觸發:流產後的情感創傷與關係變化');
            set(vars, '同伴.' + name + '.劇情演出', performances);
            keyLog('📝 為 ' + name + ' 生成流產劇情演出');
        }
        
        // 3. 清除待處理標記（避免重複執行）
        set(vars, '同伴.' + name + '.生理狀態.流產待處理', false);
        
        keyLog('✅ ' + name + ' 流產後續清理完成');
    }
}

    // ======================== 主修正函數 ========================
function applyCorrections(vars, oldVars) {
    fixCount = 0;
    delCount = 0;
    debugLog('修正開始');

    applyIntegerAndBounds(vars);
    
    try {
        ensurePaths(vars);
        fixTimeFormat(vars);
        
        processStatusEffects(vars);
        processCompanionStatusEffects(vars);
        processMiscarriageCleanup(vars);
        processTimeAndLevel(vars, oldVars);
        
        // 🔴 每次更新都重新計算懷孕天數和階段
        updatePregnancyStage(vars, '');  // 主角
        var companions = get(vars, '同伴');
        if (_.isPlainObject(companions)) {
            for (var name in companions) {
                if (name.startsWith('$')) continue;
                updatePregnancyStage(vars, '同伴.' + name);
            }
        }

        fixItemStatusLimits(vars);
        cleanupAllItems(vars);
        processItemDecay(vars);
        
        // 時間差計算（每小時更新）
        if (lastSnapshot) {
            var prevTime = lastSnapshot.time;
            var curTime = get(vars, '系統.當前時間');
            if (prevTime && curTime) {
                var hoursDiff = calculateTimeDifference(prevTime, curTime);
                if (hoursDiff > 0 && hoursDiff < 24) {
                    debugLog('時間差計算: ' + hoursDiff + ' 小時');

                    // ========== 自動入睡/喚醒規則（22:00-07:00）==========
                    var currentTime = get(vars, '系統.當前時間');
                    if (currentTime && typeof currentTime === 'string') {
                        var hour = parseInt(currentTime.split(':')[0]);
                        if (!isNaN(hour)) {
                            var shouldBeSleeping = (hour >= 22 || hour < 8);
                            var isCurrentlySleeping = get(vars, '狀態.入睡') === true;
                            
                            if (shouldBeSleeping && !isCurrentlySleeping) {
                                set(vars, '狀態.入睡', true);
                                keyLog('😴 自動入睡：時間 ' + currentTime + ' 進入睡眠狀態');
                            } else if (!shouldBeSleeping && isCurrentlySleeping) {
                                set(vars, '狀態.入睡', false);
                                keyLog('⏰ 自動喚醒：時間 ' + currentTime + ' 結束睡眠狀態');
                            }
                        }
                    }

                    var isSleeping = get(vars, '狀態.入睡') === true;
                    var sleepMultiplier = isSleeping ? 0.5 : 1.0;

                    if (isSleeping) {
                        keyLog('😴 當前為睡眠狀態，消耗減半');
                    }
                    
                    // 水分消耗
                    var water = get(vars, '生理.水分') || 0;
                    set(vars, '生理.水分', Math.max(0, water - 1.5 * hoursDiff * sleepMultiplier));
                    
                    // 碳水消耗
                    var carbs = get(vars, '生理.碳水') || 0;
                    set(vars, '生理.碳水', Math.max(0, carbs - 100 * hoursDiff * sleepMultiplier));
                    
                    // 脂肪消耗
                    var fat = get(vars, '生理.脂肪') || 0;
                    set(vars, '生理.脂肪', Math.max(0, fat - 100 * hoursDiff * sleepMultiplier));
                    
                    // 氮平衡
                    var nitrogen = get(vars, '生理.氮平衡') || 0;
                    set(vars, '生理.氮平衡', Math.max(-100, nitrogen - 1 * hoursDiff * sleepMultiplier));
                    
                    // 維生素
                    var vitamin = get(vars, '生理.維生素') || 0;
                    set(vars, '生理.維生素', Math.max(0, vitamin - 0.5 * hoursDiff * sleepMultiplier));
                    
                    // 睡眠值
                    var sleep = get(vars, '精神.睡眠') || 0;
                    if (isSleeping) {
                        set(vars, '精神.睡眠', Math.min(100, sleep + 8 * hoursDiff));
                    } else {
                        set(vars, '精神.睡眠', Math.max(0, sleep - 2 * hoursDiff));
                    }
                    
                    // 飽腹感
                    var fullness = get(vars, '生理.飽腹感') || 0;
                    set(vars, '生理.飽腹感', Math.max(0, fullness - 4 * hoursDiff * sleepMultiplier));
                    
                    // 疲勞
                    var end = int(get(vars, '屬性.耐力.等級')) || 20;
                    var fatigueMax = 4 * end;
                    var fatigue = get(vars, '狀態.疲勞') || 0;
                    if (isSleeping) {
                        set(vars, '狀態.疲勞', Math.max(0, fatigue - 4 * hoursDiff));
                    } else {
                        set(vars, '狀態.疲勞', Math.min(fatigueMax, fatigue + 2 * hoursDiff));
                    }
                    
                    // 排泄欲
                    var excretionVal = get(vars, '生理.排泄欲') || 0;
                    set(vars, '生理.排泄欲', Math.min(100, excretionVal + 2 * hoursDiff * sleepMultiplier));
                    
                    // 同伴的日常消耗
                    var companions = get(vars, '同伴');
                    if (_.isPlainObject(companions)) {
                        for (var name in companions) {
                            if (name.startsWith('$')) continue;
                            
                            var compEnd = int(get(vars, '同伴.' + name + '.屬性.耐力.等級')) || 20;
                            var compFatigueMax = 4 * compEnd;
                            
                            var compFullness = get(vars, '同伴.' + name + '.生理.飽腹感') || 0;
                            var compWater = get(vars, '同伴.' + name + '.生理.水分') || 0;
                            var compExcretion = get(vars, '同伴.' + name + '.生理.排泄欲') || 0;
                            var compFatigue = get(vars, '同伴.' + name + '.狀態.疲勞') || 0;
                            var compClean = get(vars, '同伴.' + name + '.狀態.清潔') || 0;
                            var compSleep = get(vars, '同伴.' + name + '.精神.睡眠') || 100;
                            var compStress = get(vars, '同伴.' + name + '.精神.壓力') || 0;
                            
                            var compIsSleeping = isSleeping;
                            
                            var newFullness = compFullness - 4 * hoursDiff * (compIsSleeping ? 0.5 : 1);
                            set(vars, '同伴.' + name + '.生理.飽腹感', Math.max(0, Math.min(100, newFullness)));
                            
                            var newWater = compWater - 1.5 * hoursDiff * (compIsSleeping ? 0.5 : 1);
                            set(vars, '同伴.' + name + '.生理.水分', Math.max(0, Math.min(100, newWater)));
                            
                            var newExcretion = compExcretion + 2 * hoursDiff * (compIsSleeping ? 0.5 : 1);
                            set(vars, '同伴.' + name + '.生理.排泄欲', Math.min(100, newExcretion));
                            
                            var newFatigue;
                            if (compIsSleeping) {
                                newFatigue = compFatigue - 4 * hoursDiff;
                                set(vars, '同伴.' + name + '.狀態.疲勞', Math.max(0, Math.min(compFatigueMax, newFatigue)));
                            } else {
                                newFatigue = compFatigue + 2 * hoursDiff;
                                set(vars, '同伴.' + name + '.狀態.疲勞', Math.min(compFatigueMax, newFatigue));
                            }
                            
                            var newClean = compClean - 0.5 * hoursDiff;
                            set(vars, '同伴.' + name + '.狀態.清潔', Math.max(0, Math.min(100, newClean)));
                            
                            var newSleep;
                            if (compIsSleeping) {
                                newSleep = compSleep + 8 * hoursDiff;
                                set(vars, '同伴.' + name + '.精神.睡眠', Math.min(100, newSleep));
                            } else {
                                newSleep = compSleep - 2 * hoursDiff;
                                set(vars, '同伴.' + name + '.精神.睡眠', Math.max(0, newSleep));
                            }
                            
                            var newStress = compStress + 0.2 * hoursDiff;
                            if (newClean < 30) newStress += 0.3 * hoursDiff;
                            if (newFullness < 30) newStress += 0.3 * hoursDiff;
                            set(vars, '同伴.' + name + '.精神.壓力', Math.min(100, Math.max(0, newStress)));
                        }
                    }

                    if (isSleeping) {
                        keyLog('😴 睡眠狀態消耗 (主角): 水分-' + (1.5 * hoursDiff * sleepMultiplier).toFixed(1) + 
                               ', 飽腹感-' + (4 * hoursDiff * sleepMultiplier).toFixed(1) + 
                               ', 疲勞-' + (4 * hoursDiff).toFixed(1) + ' (恢復)');
                    } else {
                        keyLog('⏰ 自動消耗 (主角): 水分-' + (1.5 * hoursDiff).toFixed(1) + 
                               ', 飽腹感-' + (4 * hoursDiff).toFixed(1) + 
                               ', 疲勞+' + (2 * hoursDiff).toFixed(1));
                    }

                    var companionCount = 0;
                    var sampleCompName = '';
                    if (_.isPlainObject(companions)) {
                        for (var name in companions) {
                            if (name.startsWith('$')) continue;
                            companionCount++;
                            if (sampleCompName === '') sampleCompName = name;
                        }
                    }
                    if (companionCount > 0) {
                        keyLog('👥 同伴消耗 (共 ' + companionCount + ' 位): 以 ' + sampleCompName + ' 為例 - 水分-1.5/時, 飽腹-4/時, 疲勞+' + (isSleeping ? '4(恢復)' : '2') + ', 清潔-0.5/時');
                    }
                }
            }
        }
        
        // 🔴 第二次整數化移到這裡（在所有消耗計算完成之後）
        applyIntegerAndBounds(vars);
        
        updateSeason(vars);

        recordShopHistory(vars);

        updateCropGrowthStages(vars);
        updateLivestockStates(vars);
        processTasksAndShop(vars);

        processCompanionLimits(vars);
        
        var currentTime = get(vars, '系統.當前時間');
        var currentDay = get(vars, '系統.經過天數');
        if (currentTime) set(vars, '系統.前次時間', currentTime);
        if (currentDay !== undefined) set(vars, '系統.前次天數', currentDay);
        
        var total = fixCount + delCount;
        var status = total > 0 ? 'fixed' : 'normal';
        var msg = total > 0 ? '修正' + fixCount + '處，清理' + delCount + '件物品' : '所有數據均符合規則，無需修正';
        if (total > 0) keyLog('修正完成 - ' + msg);
        else debugLog('修正完成 - ' + msg);
        
        checkAndRestoreSustainableCrops(vars, oldVars);
        verifyAndFixAllCrops(vars);
        verifyAndFixAllLivestock(vars);

        cleanupCompletedPerformances(vars);

        updateStatus(vars, status, msg);
        
    } catch(e) {
        errorLog('修正錯誤:', e.message);
        if (DEBUG_MODE) console.error(e.stack);
        updateStatus(vars, 'error', e.message);
    }
}

    // ======================== 事件掛載 ========================
    eventOn(Mvu.events.VARIABLE_UPDATE_STARTED, function(vars) {
        var d = vars.stat_data;
        var currentDay = get(d, '系統.經過天數');
        var currentTime = get(d, '系統.當前時間');
        
        lastSnapshot = {
            day: currentDay,
            time: currentTime,
            hpMax: get(d, '生理.生命值上限'),
            hpCur: get(d, '生理.當前生命值'),
            spMax: get(d, '精神.精神值上限'),
            spCur: get(d, '精神.當前精神值')
        };
        debugLog('記錄前次狀態: 天數=' + currentDay + ', 時間=' + currentTime);
        fixCount = 0;
        delCount = 0;
        lastLogHash = '';
    });

eventOn(Mvu.events.VARIABLE_UPDATE_ENDED, function(newVars, oldVars) {
    if (isProcessing) return;
    isProcessing = true;
    try {
        // ========== 1. 執行修正 ==========
        applyCorrections(newVars.stat_data, oldVars.stat_data);
        var vars = newVars.stat_data;
        
        // ========== 2. 確保性愛結果是陣列 ==========
        var sexResults = ensureSexResultArray(vars);
        
        // ========== 3. 如果沒有性愛結果，直接結束 ==========
        if (sexResults.length === 0) {
            return;
        }
        
        // ========== 4. 處理每一筆性愛結果 ==========
        var remaining = [];
        var INITIAL_COUNTDOWN = 2;
        
        for (var i = 0; i < sexResults.length; i++) {
            var result = sexResults[i];
            
            // =============================================
            // 情況 A：新事件（沒有刪除倒數）
            // =============================================
            if (result.刪除倒數 === undefined || result.刪除倒數 === null) {
                
                // ----- 以下：原本的「補充計算」邏輯（完整保留）-----
                var name = result.角色;
                
                if (name) {
                    var base = '同伴.' + name;
                    
                    // 1. 獲取計算參數
                    var affection = v(get(vars, base + '.技能.好感(對阿彬).等級'), 1);
                    var forced = v(get(vars, base + '.淪陷.強制次數'), 0);
                    var special = get(vars, base + '.淪陷.特殊狀態') || '';
                    var comfort = get(vars, '環境.舒適度') || 50;
                    
                    var statusEffects = [];
                    var compEff = get(vars, base + '.狀態.生效效果');
                    if (_.isPlainObject(compEff)) {
                        for (var k in compEff) {
                            if (k.startsWith('$')) continue;
                            if (compEff[k] && compEff[k].狀態) {
                                statusEffects.push(compEff[k].狀態);
                            }
                        }
                    }
                    
                    var isSudden = (result.有預警 === false);
                    var hasTrauma = (special.indexOf('關係動搖') !== -1 || special.indexOf('嚴重創傷') !== -1);
                    
                    // 2. 計算自願度
                    var voluntary = calculateVoluntary(
                        affection,
                        result.情境 || '情感推進',
                        statusEffects,
                        comfort,
                        isSudden,
                        hasTrauma,
                        special
                    );
                    var grade = getResultGrade(voluntary);
                    
                    // 3. 計算淪陷階段
                    var newCorruption = getCorruptionStage(forced, affection);
                    
                    // 4. 計算關係變化
                    var change = calculateAffectionChange(
                        voluntary,
                        affection,
                        result.情境 || '情感推進',
                        special,
                        result.完成 !== false
                    );
                    
                    // 5. 建立完整的 updatedResult（和原本完全一樣）
                    var updatedResult = {
                        角色: result.角色,
                        完成: result.完成,
                        內射: result.內射,
                        避孕措施: result.避孕措施 || '無',
                        情境: result.情境 || '情感推進',
                        自願度: voluntary,
                        自願分級: grade.grade,
                        描寫建議: grade.description,
                        淪陷階段: {
                            階段: newCorruption.stage,
                            名稱: newCorruption.name
                        },
                        關係變化: {
                            經驗變化: change.expChange,
                            等級變化: change.levelChange
                        },
                        特殊狀態: change.newSpecialStatus || '無',
                        刪除倒數: INITIAL_COUNTDOWN,
                        授精者: result.授精者 || '阿彬'
                    };
                    
                    // 寫回更新後的結果
                    sexResults[i] = updatedResult;
                    result = updatedResult;
                    
                    // 6. 執行懷孕判斷（和原本完全一樣）
                    if (result.完成 === true && result.內射 === true) {
                        calculatePregnancy(vars, name, true, result.避孕措施);
                    }
                    
                    // 7. 執行好感度更新（和原本完全一樣）
                    if (change && (change.expChange !== 0 || change.levelChange !== 0)) {
                        var currentExp = get(vars, base + '.技能.好感(對阿彬).當前經驗') || 0;
                        var currentLevel = get(vars, base + '.技能.好感(對阿彬).等級') || 1;
                        
                        var newExp = Math.max(0, currentExp + change.expChange);
                        var newLevel = Math.max(1, currentLevel + change.levelChange);
                        
                        if (newExp !== currentExp) {
                            set(vars, base + '.技能.好感(對阿彬).當前經驗', newExp);
                        }
                        if (newLevel !== currentLevel) {
                            set(vars, base + '.技能.好感(對阿彬).等級', newLevel);
                        }
                    }
                    
                    // 8. 執行淪陷階段更新（和原本完全一樣）
                    if (newCorruption.stage !== undefined) {
                        var currentStage = get(vars, base + '.淪陷.當前階段') || 0;
                        if (newCorruption.stage !== currentStage) {
                            set(vars, base + '.淪陷.當前階段', newCorruption.stage);
                        }
                    }
                    
                    // 9. 執行特殊狀態更新（和原本完全一樣）
                    if (change.newSpecialStatus && change.newSpecialStatus !== special) {
                        set(vars, base + '.淪陷.特殊狀態', change.newSpecialStatus);
                    }
                }
                
                // 保留這筆記錄（倒數還沒歸零）
                remaining.push(result);
                continue;
            }
            
            // =============================================
            // 情況 B：已有倒數 → 減數或清除
            // =============================================
            result.刪除倒數--;
            if (result.刪除倒數 > 0) {
                remaining.push(result);
            }
            // 倒數歸零則不保留（自動清除）
        }
        
        // ========== 5. 寫回更新後的陣列 ==========
        set(vars, '系統.性愛結果', remaining);
        
    } catch(e) {
        errorLog('處理錯誤:', e);
        if (DEBUG_MODE) console.error(e.stack);
    } finally {
        isProcessing = false;
    }
});
    
    window.processSexualInteraction = processSexualInteraction;
    window.getResultGrade = getResultGrade;
    window.calculateVoluntary = calculateVoluntary;
    window.calculatePregnancy = calculatePregnancy;
    window.updateAllCrops = function(vars) { return updateCropGrowthStages(vars); };
    window.updateAllLivestock = function(vars) { return updateLivestockStates(vars); };
    window.calculateMoonPhase = calculateMoonPhase;
    window.calculateSeason = calculateSeason;
    
    window._mvuFinalStableV111 = true;
    
    console.log('✅ 所有擴充功能已載入 (v11.1 路徑更新)');
    console.log('📊 功能模塊: 好感系統 | 性愛系統 | 季節系統 | 作物系統 | 畜牧系統 | 懷孕系統 | 幼兒系統 | 排泄系統 | 任務系統 | 入眠系統 | 狀態效果');
})();