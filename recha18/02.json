            fixCount++;
            return true;
        }
    }
    
    return false;
}

    function scaleValue(oldVal, oldMax, newMax) {
        if (!Number.isFinite(oldVal) || !Number.isFinite(oldMax) || !Number.isFinite(newMax) || oldMax <= 0 || newMax <= 0) return oldVal;
        return Math.round(oldVal / oldMax * newMax);
    }
    
    function calculateTimeDifference(time1, time2) {
        if (!time1 || !time2) return 0;
        var h1 = parseInt(time1.split(':')[0]), m1 = parseInt(time1.split(':')[1]);
        var h2 = parseInt(time2.split(':')[0]), m2 = parseInt(time2.split(':')[1]);
        var minutes = (h2 * 60 + m2) - (h1 * 60 + m1);
        if (minutes < 0) minutes += 1440;
        return minutes / 60;
    }
    
function isItemInvalid(item) {
    // 檢查是否為有效物件
    if (!item || typeof item !== 'object') return true;
    
    // 🔴 空物件直接視為無效
    if (Object.keys(item).length === 0) return true;
    
    var q = get(item, '數量'),
        s = get(item, '狀態'),
        w = get(item, '重量');
    
    // 有數量欄位但數量無效
    if (q !== undefined && !(Number(q) > 0)) return true;
    
    // 有狀態欄位但狀態無效
    if (s !== undefined && !(Number(s) > 0)) return true;
    
    // 有重量欄位但重量無效
    if (w !== undefined && !(Number(w) > 0)) return true;
    
    // 🔴 沒有任何關鍵欄位（數量、狀態、重量），視為結構異常的無效物品
    if (q === undefined && s === undefined && w === undefined) return true;
    
    return false;
}
    
