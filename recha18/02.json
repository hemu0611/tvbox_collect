            new RegExp('（看起來不太新鮮的樣子）$'),
            new RegExp('（開始有些變質的跡象）$'),
            new RegExp('（明顯變質了，需要儘快處理）$'),
            new RegExp('（已經壞了，可能不適合使用）$'),
            new RegExp('（腐爛了，使用可能會有危險）$')
        ];
        patterns.forEach(function(r) { if (r.test(d)) d = d.replace(r, ''); });
        d = d.trim();
        if (val >= 50) return d;
        if (val >= 40) return d + '（看起來不太新鮮的樣子）';
        if (val >= 30) return d + '（開始有些變質的跡象）';
        if (val >= 20) return d + '（明顯變質了，需要儘快處理）';
