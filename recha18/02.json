    function parseTime(str) {
        var m = /^(\d{1,2}):(\d{2})$/.exec(str);
        return m ? parseInt(m[1]) * 60 + parseInt(m[2]) : null;
    }
    
    function parseFullTime(str) {
        var m = /第(\d+)天\s+(\d{1,2}):(\d{2})/.exec(str);
        if (!m) return null;
        var d = parseInt(m[1]), h = parseInt(m[2]), mm = parseInt(m[3]);
        return { day: d, hour: h, minute: mm, total: d * 1440 + h * 60 + mm };
    }
    
    function getCurrentTime(vars) {
        var day = get(vars, '系統.經過天數'),
