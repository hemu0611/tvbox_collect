        if (!Number.isFinite(day) || typeof time != 'string') return null;
        var m = parseTime(time);
        return m === null ? null : {
            day: day,
            hour: Math.floor(m / 60),
            minute: m % 60,
            total: day * 1440 + m
        };
    }
    
function fixTimeFormat(vars) {
    var currentTime = get(vars, '系統.當前時間');
    if (!currentTime || typeof currentTime !== 'string') return false;
    
    // 匹配字串結尾的 HH:MM 或 H:MM
    var timePattern = /(\d{1,2}):(\d{2})$/;
    var match = timePattern.exec(currentTime);
    
    if (match) {
        var hour = match[1].padStart(2, '0');
        var minute = match[2];
        var formattedTime = hour + ':' + minute;
        
        // 只有當原本不是純 HH:MM 格式時才修正
        if (currentTime !== formattedTime) {
