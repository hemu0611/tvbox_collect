                set(vars, '同伴.' + n + '.狀態', {});
            }
            if (!_.isPlainObject(get(vars, '同伴.' + n + '.狀態.生效效果'))) {
                set(vars, '同伴.' + n + '.狀態.生效效果', {});
            }                
                if (!_.isPlainObject(get(vars, '任務.羈絆.' + n))) {
                    set(vars, '任務.羈絆.' + n, {});
                }
            }
        }
        
        var pets = get(vars, '寵物');
        if (_.isPlainObject(pets)) {
            for (var n in pets) {
                if (n.startsWith('$')) continue;
                if (!_.isPlainObject(get(vars, '寵物.' + n + '.攜帶物品'))) {
                    set(vars, '寵物.' + n + '.攜帶物品', {});
                }
            }
        }
        
        var camps = get(vars, '營地');
        if (_.isPlainObject(camps)) {
            for (var c in camps) {
                if (c.startsWith('$')) continue;
                ['位置', '樣式', '物品', '食材', '醫藥', '材料', '牲畜', '設施', '奇物', '武器'].forEach(function(f) {
                    if (get(vars, '營地.' + c + '.' + f) === undefined) {
                        set(vars, '營地.' + c + '.' + f, (f === '位置' || f === '樣式') ? '' : {});
                    }
                });
            }
        }
        
        var equip = get(vars, '裝備');
        if (_.isPlainObject(equip)) {
            ['頭部', '頸部', '胸部', '其他', '背部', '左手', '右手', '腰部', '腿部', '腳部'].forEach(function(p) {
                if (get(vars, '裝備.' + p) === undefined) set(vars, '裝備.' + p, {});
            });
        }

        if (_.isPlainObject(comps)) {
            for (var n in comps) {
                if (n.startsWith('$')) continue;
                var eq = get(vars, '同伴.' + n + '.裝備');
                if (!_.isPlainObject(eq)) {
                    eq = {};
                    ['頭部', '頸部', '胸部', '其他', '背部', '左手', '右手', '腰部', '腿部', '腳部'].forEach(function(p) { eq[p] = {}; });
                    set(vars, '同伴.' + n + '.裝備', eq);
                } else {
                    ['頭部', '頸部', '胸部', '其他', '背部', '左手', '右手', '腰部', '腿部', '腳部'].forEach(function(p) {
                        if (get(vars, '同伴.' + n + '.裝備.' + p) === undefined) {
                            set(vars, '同伴.' + n + '.裝備.' + p, {});
                        }
                    });
                }
                if (!Array.isArray(get(vars, '同伴.' + n + '.劇情演出'))) {
                    set(vars, '同伴.' + n + '.劇情演出', []);
                }
                
                var gender = get(vars, '同伴.' + n + '.基礎信息.性別');
                if (gender === '女' || gender === 'female') {
                    if (get(vars, '同伴.' + n + '.生育次數') === undefined) {
                        set(vars, '同伴.' + n + '.生育次數', 0);
                        debugLog('初始化 同伴.' + n + '.生育次數 = 0');
                    }
                }
            }
        }
        
        var userGender = get(vars, '基礎信息.性別');
        if (userGender === '女' || userGender === 'female') {
            if (get(vars, '生育次數') === undefined) {
                set(vars, '生育次數', 0);
                debugLog('初始化 主角.生育次數 = 0');
            }
        }
        
        if (get(vars, '系統.前次時間') === undefined) {
            set(vars, '系統.前次時間', '00:00');
            debugLog('初始化 系統.前次時間 = 00:00');
        }
        if (get(vars, '系統.前次天數') === undefined) {
            set(vars, '系統.前次天數', 1);
            debugLog('初始化 系統.前次天數 = 1');
        }

        if (!_.isPlainObject(get(vars, '養殖'))) set(vars, '養殖', {});
        
        var shop = get(vars, '商店');
        if (!_.isPlainObject(shop)) set(vars, '商店', {});
    }

    // ======================== 等級升級處理 ========================
    function processLevelUp(vars, basePath) {
        var obj = get(vars, basePath);
        if (!_.isPlainObject(obj)) return;
        var isAttr = basePath.indexOf('屬性') !== -1,
            baseExp = isAttr ? 10 : 100;
        
        for (var k in obj) {
            if (k.startsWith('$')) continue;
            var item = obj[k];
            if (!_.isPlainObject(item)) continue;
            var lv = int(get(item, '等級')) || 0,
                exp = int(get(item, '當前經驗')) || 0,
                changed = false,
                oldLv = lv;
            
            while (exp >= Math.max(1, lv * baseExp)) {
                exp -= lv * baseExp;
                lv++;
                changed = true;
            }
            
            if (changed) {
                set(vars, basePath + '.' + k + '.等級', lv);
                set(vars, basePath + '.' + k + '.當前經驗', exp);
                logChange('等級提升', basePath + '.' + k + ' ' + oldLv + ' → ' + lv);
                fixCount++;
            }
            
            var need = Math.max(1, lv * baseExp);
            if (get(item, '升級所需經驗') !== need) {
                set(vars, basePath + '.' + k + '.升級所需經驗', need);
            }
        }
    }

    // ======================== 同伴邊界限制 ========================
function processCompanionLimits(vars) {
    var comps = get(vars, '同伴');
    if (_.isPlainObject(comps)) {
        for (var n in comps) {
            if (n.startsWith('$')) continue;
            var base = '同伴.' + n;
            
            // ========== 邊界修正（更新為正確路徑） ==========
            // 生理數值
            var bounds = [
                { p: base + '.生理.水分', min: 0, max: 100 },
                { p: base + '.生理.飽腹感', min: 0, max: 100 },
                { p: base + '.生理.排泄欲', min: 0, max: 100 },
                // 精神數值
                { p: base + '.精神.壓力', min: 0, max: 100 },
                { p: base + '.精神.睡眠', min: 0, max: 100 },
                // 次生屬性
                { p: base + '.狀態.疲勞', min: 0, max: 4 * (get(vars, base + '.屬性.耐力.等級') || 20) },
                { p: base + '.狀態.清潔', min: 0, max: 100 },
                // 核心狀態（生命/精神值）
                { p: base + '.生理.當前生命值', min: 0, max: get(vars, base + '.生理.生命值上限') || 100 },
                { p: base + '.精神.當前精神值', min: 0, max: get(vars, base + '.精神.精神值上限') || 100 }
            ];
            
            bounds.forEach(function(b) {
                var val = get(vars, b.p);
                if (typeof val === 'number' && Number.isFinite(val)) {
                    var maxVal = typeof b.max === 'function' ? b.max(vars) : b.max;
                    var minVal = b.min;
                    var newVal = clamp(val, minVal, maxVal);
                    if (!Number.isInteger(newVal)) newVal = Math.round(newVal);
                    if (newVal !== val) {
                        set(vars, b.p, newVal);
                        logChange('同伴邊界修正', b.p + ' ' + val + ' → ' + newVal);
                        fixCount++;
                    }
                }
            });
            
            // ========== 技能經驗修正 ==========
            var skills = get(vars, base + '.技能');
            if (_.isPlainObject(skills)) {
                for (var skillName in skills) {
                    if (skillName.startsWith('$')) continue;
                    var exp = get(vars, base + '.技能.' + skillName + '.當前經驗');
                    if (typeof exp === 'number' && exp < 0) {
                        set(vars, base + '.技能.' + skillName + '.當前經驗', 0);
                        logChange('技能經驗修正', base + '.' + skillName + ' 經驗 ' + exp + ' → 0');
                        fixCount++;
                    }
                }
            }
            
            // ✅ 在這裡添加屬性經驗修正（在技能經驗修正之後）
            var attrs = ['力量', '敏捷', '耐力', '智力', '感知', '意志'];
            for (var i = 0; i < attrs.length; i++) {
                var attr = attrs[i];
                var exp = get(vars, base + '.屬性.' + attr + '.當前經驗');
                if (typeof exp === 'number' && exp < 0) {
                    set(vars, base + '.屬性.' + attr + '.當前經驗', 0);
                    logChange('同伴屬性經驗修正', base + '.' + attr + ' 經驗 ' + exp + ' → 0');
                    fixCount++;
                }
            }
            
            // ========== 等級升級 ==========
            processLevelUp(vars, base + '.屬性');
            processLevelUp(vars, base + '.技能');
        }
    }
    
    // 寵物邊界修正（如果有的話）
    var pets = get(vars, '寵物');
    if (_.isPlainObject(pets)) {
        for (var n in pets) {
            if (n.startsWith('$')) continue;
            var base = '寵物.' + n;
            var fav = get(vars, base + '.好感度');
            if (Number.isFinite(fav)) {
                var newFav = clamp(fav, 0, 100);
                if (!Number.isInteger(newFav)) newFav = Math.round(newFav);
                if (newFav !== fav) {
                    set(vars, base + '.好感度', newFav);
                    logChange('邊界修正', base + '.好感度 ' + fav + ' → ' + newFav);
                    fixCount++;
                }
            }
            processLevelUp(vars, base + '.屬性');
            processLevelUp(vars, base + '.技能');
        }
    }
}

    // ======================== 物品狀態上限修正 ========================
    function fixItemStatusLimits(vars) {
        var paths = ['攜帶物品', '裝備', '捷徑或裝置'];
        paths.forEach(function(p) {
            var items = get(vars, p);
            if (!_.isPlainObject(items)) return;
            for (var k in items) {
                if (k.startsWith('$')) continue;
                var s = get(items[k], '狀態');
                if (Number.isFinite(s) && s > 100) {
                    set(vars, p + '.' + k + '.狀態', 100);
                    logChange('物品狀態上限', p + '.' + k + ' ' + s + ' → 100');
                    fixCount++;
                }
            }
        });
        
        var camps = get(vars, '營地');
        if (_.isPlainObject(camps)) {
            for (var c in camps) {
                if (c.startsWith('$')) continue;
                var cats = ['物品', '食材', '醫藥', '材料', '牲畜', '設施', '奇物', '武器'];
                cats.forEach(function(cat) {
                    var items = get(vars, '營地.' + c + '.' + cat);
                    if (!_.isPlainObject(items)) return;
                    for (var k in items) {
                        if (k.startsWith('$')) continue;
                        var s = get(items[k], '狀態');
                        if (Number.isFinite(s) && s > 100) {
                            set(vars, '營地.' + c + '.' + cat + '.' + k + '.狀態', 100);
                            logChange('物品狀態上限', '營地.' + c + '.' + cat + '.' + k + ' ' + s + ' → 100');
                            fixCount++;
                        }
                    }
                });
            }
        }
    }

    // ======================== 清理無效物品 ========================
function cleanupAllItems(vars) {
    var paths = ['攜帶物品', '捷徑或裝置'];  // 🔴 移除 '裝備'
    
    function fixItemNumbers(item, itemPath) {
        if (!_.isPlainObject(item)) return;
        var changed = false;
        var s = get(item, '狀態');
        if (Number.isFinite(s) && !Number.isInteger(s)) {
            var newS = Math.round(s);
            set(item, '狀態', newS);
            logChange('狀態取整', itemPath + ' 狀態 ' + s + ' → ' + newS);
            fixCount++;
            changed = true;
        }
        var w = get(item, '重量');
        if (Number.isFinite(w)) {
            var newW = Math.round(w * 100) / 100;
            if (newW !== w) {
                set(item, '重量', newW);
                logChange('重量修正', itemPath + ' 重量 ' + w + ' → ' + newW);
                fixCount++;
                changed = true;
            }
        }
        var q = get(item, '數量');
        if (Number.isFinite(q)) {
            var rounded = Math.round(q);
            if (Math.abs(q - rounded) < 1e-10 && rounded !== q) {
                set(item, '數量', rounded);
                logChange('數量誤差修正', itemPath + ' 數量 ' + q + ' → ' + rounded);
                fixCount++;
                changed = true;
            }
        }
        return changed;
    }
    
    // 🔴 只處理攜帶物品和捷徑，不處理裝備
    paths.forEach(function(p) {
        var items = get(vars, p);
        if (!_.isPlainObject(items)) return;
        var toDel = [];
        for (var k in items) {
            if (k.startsWith('$')) continue;
            var item = items[k];
            fixItemNumbers(item, p + '.' + k);
            if (isItemInvalid(item)) toDel.push(k);
        }
        if (toDel.length) {
            toDel.forEach(function(k) { _.unset(vars, p + '.' + k); });
            logChange('清理異常物品', p + ': ' + toDel.join(', '));
            delCount += toDel.length;
        }
    });
    
    // 營地物品處理（保持不變）
    var camps = get(vars, '營地');
    if (_.isPlainObject(camps)) {
        for (var c in camps) {
            if (c.startsWith('$')) continue;
            var cats = ['物品', '食材', '醫藥', '材料', '牲畜', '設施', '奇物', '武器'];
            cats.forEach(function(cat) {
                var items = get(vars, '營地.' + c + '.' + cat);
                if (!_.isPlainObject(items)) return;
                var toDel = [];
                for (var k in items) {
                    if (k.startsWith('$')) continue;
                    var item = items[k];
                    fixItemNumbers(item, '營地.' + c + '.' + cat + '.' + k);
                    if (isItemInvalid(item)) toDel.push(k);
                }
                if (toDel.length) {
                    toDel.forEach(function(k) { _.unset(vars, '營地.' + c + '.' + cat + '.' + k); });
                    logChange('清理營地異常物品', c + '/' + cat + ': ' + toDel.join(', '));
                    delCount += toDel.length;
                }
            });
        }
    }
    
    // 同伴攜帶物品（保持不變）
    var comps = get(vars, '同伴');
    if (_.isPlainObject(comps)) {
        for (var n in comps) {
            if (n.startsWith('$')) continue;
            var items = get(vars, '同伴.' + n + '.攜帶物品');
            if (!_.isPlainObject(items)) continue;
            var toDel = [];
            for (var k in items) {
                if (k.startsWith('$')) continue;
                var item = items[k];
                fixItemNumbers(item, '同伴.' + n + '.攜帶物品.' + k);
                if (isItemInvalid(item)) toDel.push(k);
            }
            if (toDel.length) {
                toDel.forEach(function(k) { _.unset(vars, '同伴.' + n + '.攜帶物品.' + k); });
                logChange('清理同伴異常物品', n + ': ' + toDel.join(', '));
                delCount += toDel.length;
            }
        }
    }
    
    // 寵物攜帶物品（保持不變）
    var pets = get(vars, '寵物');
    if (_.isPlainObject(pets)) {
        for (var n in pets) {
            if (n.startsWith('$')) continue;
            var items = get(vars, '寵物.' + n + '.攜帶物品');
            if (!_.isPlainObject(items)) continue;
            var toDel = [];
            for (var k in items) {
                if (k.startsWith('$')) continue;
                var item = items[k];
                fixItemNumbers(item, '寵物.' + n + '.攜帶物品.' + k);
                if (isItemInvalid(item)) toDel.push(k);
            }
            if (toDel.length) {
                toDel.forEach(function(k) { _.unset(vars, '寵物.' + n + '.攜帶物品.' + k); });
                logChange('清理寵物異常物品', n + ': ' + toDel.join(', '));
                delCount += toDel.length;
            }
        }
    }
}

    // ======================== 物品腐敗處理 ========================
    function decayLocation(vars, basePath, hours, factor) {
        var items = get(vars, basePath);
        if (!_.isPlainObject(items)) return;
        
        (function walk(path, obj) {
            if (!_.isPlainObject(obj)) return;
            for (var k in obj) {
                if (k.startsWith('$')) continue;
                var v = obj[k];
                if (_.isPlainObject(v)) {
                    var shelf = int(get(v, '保質期'));
                    if (shelf >= 1 && shelf <= 5) {
                        var state = int(get(v, '狀態'));
                        if (state > 0) {
                            var decay = decayRates[5 - shelf] * hours * factor,
                                newState = Math.max(0, Math.round(state - decay));
                            if (newState !== state) {
                                set(vars, path + '.' + k + '.狀態', newState);
                                var desc = get(v, '描述'),
                                    newDesc = updateDesc(desc, newState);
                                if (newDesc !== desc) set(vars, path + '.' + k + '.描述', newDesc);
                            }
                        }
                    }
                    walk(path + '.' + k, v);
                }
            }
        })(basePath, items);
    }
    
    function processItemDecay(vars) {
        if (!lastSnapshot) return;
        var cur = getCurrentTime(vars);
        if (!cur) return;
        var prevDay = lastSnapshot.day,
            prevTime = lastSnapshot.time;
        if (!prevDay || !prevTime) return;
        var prevMins = prevDay * 1440 + parseTime(prevTime),
            curMins = cur.total,
            delta = curMins - prevMins;
        if (delta <= 0) return;
        
        var hours = delta / 60,
            avgTemp = int(get(vars, '環境.體感溫度')) || 25,
            factor = tempFactor(avgTemp);
        
        ['攜帶物品', '裝備', '捷徑或裝置'].forEach(function(p) {
            decayLocation(vars, p, hours, factor);
        });
        
        var camps = get(vars, '營地');
        if (_.isPlainObject(camps)) {
            for (var c in camps) {
                if (c.startsWith('$')) continue;
                ['物品', '食材', '醫藥', '材料', '奇物', '武器'].forEach(function(cat) {
                    decayLocation(vars, '營地.' + c + '.' + cat, hours, factor);
                });
            }
        }
        
        var comps = get(vars, '同伴');
        if (_.isPlainObject(comps)) {
            for (var n in comps) {
                if (n.startsWith('$')) continue;
                decayLocation(vars, '同伴.' + n + '.攜帶物品', hours, factor);
            }
        }
        
        var pets = get(vars, '寵物');
        if (_.isPlainObject(pets)) {
            for (var n in pets) {
                if (n.startsWith('$')) continue;
                decayLocation(vars, '寵物.' + n + '.攜帶物品', hours, factor);
            }
        }
    }

    // ==================== 季節系統 ====================
    function calculateSeason(currentDay) {
        var total = SEASON_CONFIG.SPRING_DAYS + SEASON_CONFIG.SUMMER_DAYS + 
                    SEASON_CONFIG.AUTUMN_DAYS + SEASON_CONFIG.WINTER_DAYS;
        var pos = currentDay % total;
        var acc = 0;
        
        acc += SEASON_CONFIG.SPRING_DAYS;
        if (pos < acc) return '春季';
        acc += SEASON_CONFIG.SUMMER_DAYS;
        if (pos < acc) return '夏季';
        acc += SEASON_CONFIG.AUTUMN_DAYS;
        if (pos < acc) return '秋季';
        return '冬季';
    }

    function updateSeason(vars) {
        var currentDay = v(get(vars, '系統.經過天數'), 0);
        var newSeason = calculateSeason(currentDay);
        var currentSeason = get(vars, '環境.季節');
        
        if (newSeason !== currentSeason) {
            set(vars, '環境.季節', newSeason);
            keyLog('季節更新: ' + currentSeason + ' → ' + newSeason);
            debugLog('季節計算 - 當前天數: ' + currentDay + ', 新季節: ' + newSeason);
            logChange('季節更新', currentSeason + ' → ' + newSeason);
            fixCount++;
            return true;
        }
        debugLog('季節無變化: ' + currentSeason);
        return false;
    }

    // ==================== 懷孕系統 ====================
function updatePregnancyStage(vars, characterPath) {
    var prefix = characterPath ? characterPath + '.' : '';
    var pregnant = get(vars, prefix + '生理狀態.懷孕狀態');
    
    // 🔴 加入 '流產' 到排除清單
    if (!pregnant || pregnant === '未懷孕' || pregnant === '' || pregnant === '流產') {
        return false;
    }
    
    // 🔴 使用計算函數獲取懷孕天數
    var days = calculatePregnancyDays(vars, characterPath);
    
    // 如果懷孕天數為 0 且懷孕日不存在，可能出了問題
    if (days === 0 && get(vars, prefix + '生理狀態.懷孕日') === undefined) {
        // 回退到讀取儲存的天數
        days = get(vars, prefix + '生理狀態.懷孕天數') || 0;
    }
    
    var newStage = null;
    if (days <= 30) {
        newStage = '懷孕初期';
    } else if (days <= 60) {
        newStage = '懷孕中期';
    } else {
        newStage = '懷孕後期';
    }
    
    // 自動分娩（超過 90 天）
    if (days > 90) {
        var name = characterPath ? characterPath.split('.').pop() : '主角';
        var motherPath = characterPath || '主角';
        
        keyLog('🤰 ' + name + ' 懷孕 ' + days + ' 天，自動分娩！');
        var litterCount = generateNewborn(vars, name, motherPath);
        
        set(vars, prefix + '生理狀態.懷孕狀態', '未懷孕');
        set(vars, prefix + '生理狀態.懷孕天數', 0);
        set(vars, prefix + '生理狀態.懷孕日', 0);  // 🔴 清空懷孕日
        set(vars, prefix + '生理狀態.月經週期', 1);
        logChange('分娩', name + ' 順利分娩，生下 ' + litterCount + ' 胎');
        fixCount++;
        return true;
    }
    
    // 更新懷孕狀態
    if (newStage && newStage !== pregnant) {
        keyLog('🤰 ' + (characterPath || '主角') + ' 懷孕階段更新: ' + pregnant + ' → ' + newStage + ' (第' + days + '天)');
        set(vars, prefix + '生理狀態.懷孕狀態', newStage);
        logChange('懷孕階段', (characterPath || '主角') + ' ' + pregnant + ' → ' + newStage);
        fixCount++;
        return true;
    }
    return false;
}

function advancePregnancy(vars, days) {
    // 現在天數由 calculatePregnancyDays 計算，這個函數只需要更新階段
    var changed = false;
    
    // 更新主角
    if (updatePregnancyStage(vars, '')) changed = true;
    
    // 更新同伴
    var companions = get(vars, '同伴');
    if (_.isPlainObject(companions)) {
        for (var name in companions) {
            if (name.startsWith('$')) continue;
            if (updatePregnancyStage(vars, '同伴.' + name)) changed = true;
        }
    }
    
    return changed;
}

function calculatePregnancy(vars, characterName, isInternalEjaculation, contraceptive) {
    var base = '同伴.' + characterName;
    
    // 1. 先檢查性別
    var gender = get(vars, base + '.基礎信息.性別');
    if (gender !== '女' && gender !== 'female' && gender !== '女性') {
        keyLog('🔍 [2] 性別不符，跳過 (性別=' + gender + ')');
        return false;
    }
    
    // 2. 再檢查懷孕狀態（流產視為未懷孕）
    var pregnancyState = get(vars, base + '.生理狀態.懷孕狀態');
    if (pregnancyState && pregnancyState !== '未懷孕' && pregnancyState !== '流產') {
        keyLog('🔍 [4] 已懷孕，跳過');
        return false;
    }
    
    // 3. 有效避孕檢查
    if (contraceptive === '保險套' || contraceptive === '避孕藥') {
        keyLog('🔍 [5] 有效避孕，懷孕機率=0%');
        set(vars, base + '.生理狀態.懷孕天數', 0);
        return false;
    }
    
    // 4. 獲取授精者
    var sexResults = ensureSexResultArray(vars);
    var inseminator = '未知';
    for (var i = 0; i < sexResults.length; i++) {
        if (sexResults[i].角色 === characterName && sexResults[i].授精者) {
            inseminator = sexResults[i].授精者;
            break;
        }
    }
    if (inseminator === '未知') {
        inseminator = get(vars, '基礎信息.名字') || '未知';
    }
    
    keyLog('🔍 [1] 懷孕判斷入口: 角色=' + characterName + ', 性別=' + gender);
    keyLog('🔍 [6] 通過所有檢查，開始計算機率');
    
    var isPullOut = (contraceptive === '體外射精');
    
    var cycleDay = get(vars, base + '.生理狀態.月經週期') || 14;
    var cyclePhase = '安全期';
    if (cycleDay >= 1 && cycleDay <= 5) cyclePhase = '月經期';
    else if (cycleDay >= 10 && cycleDay <= 16) cyclePhase = '危險期';
    keyLog('🔍 [7] 月經週期: 第' + cycleDay + '天, 階段: ' + cyclePhase);
    
    var baseChance = 0;
    if (cyclePhase === '危險期') {
       baseChance = isInternalEjaculation ? 25 : 8;
    } else if (cyclePhase === '安全期') {
       baseChance = isInternalEjaculation ? 2 : 0.5;
    } else {
       baseChance = isInternalEjaculation ? 0.3 : 0;
    }
    keyLog('🔍 [8] 基礎機率: ' + baseChance + '%');

    if (isPullOut && isInternalEjaculation === false) {
        baseChance = Math.floor(baseChance * 0.25);
        keyLog('🔍 [9] 體外射精，機率降低至 ' + baseChance + '%');
    }
    
    if (contraceptive === '安全期') {
        var originalChance = baseChance;
        baseChance = Math.min(baseChance, 2);
        if (originalChance !== baseChance) {
            keyLog('🔍 [10] 安全期避孕，機率從 ' + originalChance + '% 限制為 ' + baseChance + '%');
        }
    }
    
    var talentBonus = 0;
    var talents = get(vars, base + '.天賦特性');
    if (_.isPlainObject(talents)) {
        for (var talentName in talents) {
            if (talentName.startsWith('$')) continue;
            var talent = talents[talentName];
            if (talent && talent.加值 && talent.加值.懷孕) {
                var bonusValue = talent.加值.懷孕;
                if (typeof bonusValue === 'number') talentBonus += Math.floor(bonusValue / 10);
            }
        }
    }
    keyLog('🔍 [11] 天賦加成: ' + talentBonus + '%');
    
    var finalChance = Math.min(99, Math.max(0, baseChance + talentBonus));
    var dice = Math.floor(Math.random() * 100) + 1;
    var isPregnant = dice <= finalChance;
    
    keyLog('🔍 [12] 最終機率: ' + finalChance + '%, 骰子: ' + dice + ', 結果: ' + (isPregnant ? '懷孕' : '未懷孕'));
    
    if (isPregnant) {
        var currentPregnancyState = get(vars, base + '.生理狀態.懷孕狀態');
        if (!currentPregnancyState || currentPregnancyState === '未懷孕' || currentPregnancyState === '流產') {
            set(vars, base + '.生理狀態.懷孕狀態', '懷孕初期');
        }
        
        var currentDay = get(vars, '系統.經過天數') || 0;
        set(vars, base + '.生理狀態.懷孕日', currentDay);
        var pregnancyDays = 0;
        set(vars, base + '.生理狀態.懷孕天數', pregnancyDays);
        set(vars, base + '.生理狀態.授精者', inseminator);
        
        keyLog('🤰 ' + characterName + ' 懷孕了！ (懷孕日: 第' + currentDay + '天)');
        logChange('懷孕', characterName + ' 在第 ' + currentDay + ' 天懷孕，授精者: ' + inseminator);
    } else {
        set(vars, base + '.生理狀態.懷孕天數', 0);
        keyLog('❌ ' + characterName + ' 未懷孕 (週期: ' + cyclePhase + ', 機率: ' + finalChance + '%)');
    }
    return isPregnant;
}

// ==================== 計算懷孕天數（基於懷孕日） ====================
function calculatePregnancyDays(vars, characterPath) {
    var prefix = characterPath ? characterPath + '.' : '';
    var pregnant = get(vars, prefix + '生理狀態.懷孕狀態');
    
    // 如果沒有懷孕，直接返回 0
    if (!pregnant || pregnant === '未懷孕' || pregnant === '') {
        return 0;
    }
    
    var pregnancyDay = get(vars, prefix + '生理狀態.懷孕日');
    var currentDay = get(vars, '系統.經過天數') || 0;
    
    // 如果沒有懷孕日記錄，回退到原本的懷孕天數
    if (pregnancyDay === undefined || pregnancyDay === null) {
        return get(vars, prefix + '生理狀態.懷孕天數') || 0;
    }
    
    // 🔴 計算懷孕天數 = 當前天數 - 懷孕當天數
    var days = Math.max(0, currentDay - pregnancyDay);
    
    // 同步更新懷孕天數欄位（保持一致性）
    set(vars, prefix + '生理狀態.懷孕天數', days);
    
    return days;
}

function updateMenstrualCycle(vars) {
    var changed = false;
    var companions = get(vars, '同伴');
    
    if (_.isPlainObject(companions)) {
        for (var name in companions) {
            if (name.startsWith('$')) continue;
            var gender = get(vars, '同伴.' + name + '.基礎信息.性別');
            if (gender === '女' || gender === 'female' || gender === '女性') {
                var pregnant = get(vars, '同伴.' + name + '.生理狀態.懷孕狀態');
                var currentCycle = get(vars, '同伴.' + name + '.生理狀態.月經週期');
                var newCycle;
                
                // 🔴 新增：流產後重置月經週期
                if (pregnant === '流產') {
                    newCycle = 1;
                    debugLog('同伴 ' + name + ' 流產，月經週期重置為 1');
                } else if (currentCycle === undefined || currentCycle === null) {
                    newCycle = Math.floor(Math.random() * 28) + 1;
                } else {
                    newCycle = currentCycle + 1;
                    if (newCycle > 28) newCycle = 1;
                }
                set(vars, '同伴.' + name + '.生理狀態.月經週期', newCycle);
                changed = true;
            }
        }
    }
    
    // 主角同理
    var userGender = get(vars, '基礎信息.性別');
    if (userGender === '女' || userGender === 'female') {
        var userPregnant = get(vars, '生理狀態.懷孕狀態');
        var userCycle = get(vars, '生理狀態.月經週期');
        var newUserCycle;
        
        // 🔴 新增：流產後重置月經週期
        if (userPregnant === '流產') {
            newUserCycle = 1;
            debugLog('主角流產，月經週期重置為 1');
        } else if (userCycle === undefined || userCycle === null) {
            newUserCycle = Math.floor(Math.random() * 28) + 1;
        } else {
            newUserCycle = userCycle + 1;
            if (newUserCycle > 28) newUserCycle = 1;
        }
        set(vars, '生理狀態.月經週期', newUserCycle);
        changed = true;
    }
    
    if (changed) debugLog('月經週期更新完成');
    return changed;
}

    // ==================== 作物系統 ====================
    function updateCropGrowthStages(vars) {
        var changed = false;
        var currentDay = v(get(vars, '系統.經過天數'), 0);
        var crops = get(vars, '作物');
        
        if (!_.isPlainObject(crops)) return false;
        
        for (var name in crops) {
            if (name.startsWith('$')) continue;
            var data = crops[name];
            if (!_.isPlainObject(data)) continue;
            
            var growthCycle = v(data.成長週期, 0);
            var planted = v(data.種植日期, 0);
            
            if (planted <= 0) continue;
            
            var actualDays = growthCycle > 0 ? calculateActualGrowthDays(vars, name, growthCycle) : Math.abs(growthCycle);
            var stage = calculateGrowthStage(data, currentDay, actualDays);
            var currentStage = get(vars, '作物.' + name + '.生長階段');
            
            if (stage !== currentStage) {
                set(vars, '作物.' + name + '.生長階段', stage);
                keyLog('🌱 作物 ' + name + ' 生長階段: ' + currentStage + ' → ' + stage);
                changed = true;
                
                if (stage === '可收割' && !get(vars, '作物.' + name + '.已成熟')) {
                    set(vars, '作物.' + name + '.已成熟', true);
                    keyLog('🌾 作物 ' + name + ' 已成熟，可收割！');
                }
            }
            
            if (growthCycle > 0 && planted > 0) {
                var maturity = planted + actualDays;
                if (get(vars, '作物.' + name + '.收成日期') !== maturity) {
                    set(vars, '作物.' + name + '.收成日期', maturity);
                    debugLog('作物 ' + name + ' 收成日期更新: ' + maturity);
                    changed = true;
                }
            }
        }
        
        if (changed) debugLog('作物系統更新完成');
        return changed;
    }

    // ==================== 畜牧系統 ====================
    function checkAndProcessBreeding(vars, currentDay, specificAnimal) {
        var updated = false;
        var livestock = get(vars, '畜牧');
        if (!_.isPlainObject(livestock)) return { success: false, updated: false };
        
        var bred = [];
        var animals = specificAnimal ? [[specificAnimal, livestock[specificAnimal]]] : Object.entries(livestock);
        
        for (var i = 0; i < animals.length; i++) {
            var name = animals[i][0], data = animals[i][1];
            if (name.startsWith('$') || !_.isPlainObject(data)) continue;
            if (!data.繁殖 || !data.繁殖.可繁殖) continue;
            
            var stage = calculateLivestockGrowthStage(data);
            if (stage === '幼年期' || stage === '成長期') continue;
            
            var males = v(data.飼養數量?.雄性, 0), females = v(data.飼養數量?.雌性, 0);
            if (males <= 0 || females <= 0) continue;
            if (data.繁殖.懷孕中) continue;
            
            var lastBreed = v(data.繁殖.上次繁殖日, 0);
            var cooldown = LIVESTOCK_CONFIG.BREEDING_CONFIG.BREEDING_COOLDOWN[name] || 30;
            if (lastBreed > 0 && currentDay - lastBreed < cooldown) continue;
            
            var chance = LIVESTOCK_CONFIG.BREEDING_CONFIG.BASE_BREEDING_CHANCE;
            var ageMonths = v(data.年齡, 12);
            if (ageMonths >= 12 && ageMonths < 36) chance = 0.4;
            else if (ageMonths >= 36) chance = 0.2;
            
            if (Math.random() > chance) continue;
            
            set(vars, '畜牧.' + name + '.繁殖.懷孕中', true);
            set(vars, '畜牧.' + name + '.繁殖.上次繁殖日', currentDay);
            updated = true;
            bred.push(name);
            keyLog('🐄 ' + name + ' 成功懷孕！');
        }
        
        if (updated) logChange('畜牧繁殖', '懷孕動物: ' + bred.join(', '));
        return { success: bred.length > 0, updated: updated, bredAnimals: bred };
    }

    function checkAndProcessBirth(vars, currentDay, specificAnimal) {
        var updated = false;
        var livestock = get(vars, '畜牧');
        if (!_.isPlainObject(livestock)) return { success: false, updated: false };
        
        var birthed = [];
        var animals = specificAnimal ? [[specificAnimal, livestock[specificAnimal]]] : Object.entries(livestock);
        
        for (var i = 0; i < animals.length; i++) {
            var name = animals[i][0], data = animals[i][1];
            if (name.startsWith('$') || !_.isPlainObject(data)) continue;
            if (!data.繁殖?.懷孕中) continue;
            
            var lastBreed = v(data.繁殖.上次繁殖日, 0);
            var pregnancyCycle = v(data.繁殖.懷孕週期, 0);
            if (lastBreed <= 0 || pregnancyCycle <= 0) continue;
            
            var dueDay = lastBreed + pregnancyCycle;
            if (currentDay < dueDay) continue;
            
            var litter = rollDice(data.繁殖?.每胎數量 || '1d2');
            if (litter <= 0) litter = 1;
            
            var males = 0, females = 0;
            for (var j = 0; j < litter; j++) {
                if (generateRandomGender() === '雄性') males++;
                else females++;
            }
            
            var curMales = v(data.飼養數量?.雄性, 0);
            var curFemales = v(data.飼養數量?.雌性, 0);
            set(vars, '畜牧.' + name + '.飼養數量.雄性', curMales + males);
            set(vars, '畜牧.' + name + '.飼養數量.雌性', curFemales + females);
            set(vars, '畜牧.' + name + '.繁殖.懷孕中', false);
            
            updated = true;
            birthed.push(name);
            keyLog('🐣 ' + name + ' 生產了 ' + litter + ' 隻幼崽 (雄:' + males + ', 雌:' + females + ')');
        }
        
        if (updated) logChange('畜牧生產', '生產動物: ' + birthed.join(', '));
        return { success: birthed.length > 0, updated: updated, birthedAnimals: birthed };
    }

    function updateLivestockStates(vars) {
        var changed = false;
        var currentDay = v(get(vars, '系統.經過天數'), 0);
        var livestock = get(vars, '畜牧');
        
        if (!_.isPlainObject(livestock)) return false;
        
        for (var name in livestock) {
            if (name.startsWith('$')) continue;
            var data = livestock[name];
            if (!_.isPlainObject(data)) continue;
            
            var stage = calculateLivestockGrowthStage(data);
            if (stage !== get(vars, '畜牧.' + name + '.生長階段')) {
                set(vars, '畜牧.' + name + '.生長階段', stage);
                keyLog('🐑 ' + name + ' 生長階段: → ' + stage);
                changed = true;
            }
            
            var startDay = v(data.飼養開始日, 0);
            if (startDay > 0) {
                var age = Math.max(12, 12 + Math.floor((currentDay - startDay) / 30));
                if (age !== v(data.年齡, 0)) {
                    set(vars, '畜牧.' + name + '.年齡', age);
                    debugLog('畜牧 ' + name + ' 年齡更新: ' + age + '個月');
                    changed = true;
                }
            }
            
            if (data.產出物 && data.產出物.週期) {
                var baseCycle = v(data.產出物.週期, 0);
                if (baseCycle > 0) {
                    var actualCycle = calculateActualProductionCycle(vars, name, baseCycle);
                    var nextDay = v(data.產出物.下次產出日, 0);
                    
                    if (nextDay <= 0 && startDay > 0) {
                        nextDay = startDay + actualCycle;
                        set(vars, '畜牧.' + name + '.產出物.下次產出日', nextDay);
                        debugLog('畜牧 ' + name + ' 初始化產出日: ' + nextDay);
                        changed = true;
                    } else if (currentDay > nextDay && nextDay > 0) {
                        var cycles = Math.floor((currentDay - nextDay) / actualCycle) + 1;
                        set(vars, '畜牧.' + name + '.產出物.下次產出日', nextDay + cycles * actualCycle);
                        keyLog('🥚 ' + name + ' 產出物已生產！');
                        changed = true;
                    }
                    
                    if (actualCycle !== baseCycle) {
                        set(vars, '畜牧.' + name + '.產出物.週期', actualCycle);
                        debugLog('畜牧 ' + name + ' 產出週期更新: ' + baseCycle + ' → ' + actualCycle);
                        changed = true;
                    }
                }
            }
            
            var breedResult = checkAndProcessBreeding(vars, currentDay, name);
            if (breedResult.updated) changed = true;
            var birthResult = checkAndProcessBirth(vars, currentDay, name);
            if (birthResult.updated) changed = true;
        }
        
        if (changed) debugLog('畜牧系統更新完成');
        return changed;
    }

// ==================== 商店歷史記錄 ====================
// ==================== 商店歷史記錄 ====================
function recordShopHistory(vars) {
    var shop = get(vars, '商店');
    if (!_.isPlainObject(shop)) return;
    
    var history = get(vars, '系統.商店歷史');
    // 🔴 更新為 9 個類別（夥伴拆成 4 個獨立類別）
    var categories = ['材料', '工具', '奇物', '夥伴-技術與後勤', '夥伴-戰鬥與探索', '夥伴-反派與妖魅', '夥伴-純愛與保護控', '藥物', '盲盒'];
    var maxLength = 16;
    
    // 轉換舊格式（如果還是陣列）
    if (Array.isArray(history)) {
        var newHistory = {
            "材料": [],
            "工具": [],
            "奇物": [],
            "夥伴-技術與後勤": [],
            "夥伴-戰鬥與探索": [],
            "夥伴-反派與妖魅": [],
            "夥伴-純愛與保護控": [],
            "藥物": [],
            "盲盒": []
        };
        
        for (var i = 0; i < history.length; i++) {
            var day = history[i];
            if (day.商品 && Array.isArray(day.商品)) {
                for (var j = 0; j < day.商品.length; j++) {
                    var item = day.商品[j];
                    var cat = item.類別;
                    // 🔴 舊版「夥伴」轉換為四個夥伴類別時，需要判斷歸屬，但舊格式沒有子類別資訊
                    // 所以統一歸入「夥伴-技術與後勤」作為預設（或可根據名稱關鍵字判斷）
                    if (cat === '夥伴') {
                        cat = '夥伴-技術與後勤';
                    }
                    var rawName = item.名稱;
                    var cleanName = rawName.replace(/\([^)]*\)/g, '').trim();
                    
                    if (newHistory[cat] && newHistory[cat].indexOf(cleanName) === -1) {
                        newHistory[cat].push(cleanName);
                    }
                }
            }
        }
        
        history = newHistory;
        set(vars, '系統.商店歷史', history);
        keyLog('🔄 舊格式轉換完成（已刪除括弧，夥伴類別已拆分）');
    }
    
    // 確保格式正確（包含 9 個類別）
    if (!_.isPlainObject(history)) {
        history = {
            "材料": [],
            "工具": [],
            "奇物": [],
            "夥伴-技術與後勤": [],
            "夥伴-戰鬥與探索": [],
            "夥伴-反派與妖魅": [],
            "夥伴-純愛與保護控": [],
            "藥物": [],
            "盲盒": []
        };
        set(vars, '系統.商店歷史', history);
    }
    
    // 🔴 同一天不重複記錄
    var currentDay = get(vars, '系統.經過天數');
    var lastRecordDay = get(vars, '系統.上次記錄天數');
    
    if (currentDay === lastRecordDay) {
        debugLog('同一天跳過商店歷史記錄，天數=' + currentDay);
        return;
    }
    
    // 記錄當天商品（9 個類別）
    var anyChange = false;
    
    for (var i = 0; i < categories.length; i++) {
        var cat = categories[i];
        var item = shop[cat];
        if (item && typeof item === 'object' && item['名稱']) {
            var rawName = item['名稱'];
            var cleanName = rawName.replace(/\([^)]*\)/g, '').trim();
            
            var list = history[cat] || [];
            
            if (list.length >= maxLength) {
                list.shift();
            }
            
            list.push(cleanName);
            history[cat] = list;
            anyChange = true;
        }
    }
    
    if (anyChange) {
        set(vars, '系統.商店歷史', history);
        set(vars, '系統.上次記錄天數', currentDay);
        keyLog('📜 商店歷史已更新，天數=' + currentDay + '，共9個類別');
    }
}

    // ==================== 性愛系統 ====================
    function calculateVoluntary(affectionLevel, interactionType, statusEffects, comfort, isSudden, hasTrauma, specialStatus) {
        var base = 50 + (affectionLevel * 5);
        if (interactionType === '情感推進') base += 10;
        else if (interactionType === '強制欺騙') base -= 40;
        
        if (affectionLevel >= 10) base += 20;
        else if (affectionLevel >= 7) base += 10;
        else if (affectionLevel >= 4) base += 5;
        else if (affectionLevel === 1) base -= 10;
        
        if (statusEffects && statusEffects.indexOf('恐懼') !== -1) base -= 15;
        if (statusEffects && statusEffects.indexOf('壓力') !== -1) base -= 10;
        if (statusEffects && statusEffects.indexOf('興致') !== -1) base += 15;
        
        if (comfort > 80) base += 5;
        if (comfort < 30) base -= 10;
        if (isSudden) base -= 20;
        if (hasTrauma) base -= 20;
        
        if (specialStatus === '自責傾向') base -= 10;
        else if (specialStatus === '共犯') base += 20;
        
        return Math.max(0, Math.min(100, base));
    }

    function getResultGrade(voluntary) {
        if (voluntary >= 90) return { grade: '高度自願-主動', description: '主動推進 + 愉悅表現' };
        if (voluntary >= 80) return { grade: '高度自願-積極', description: '積極配合 + 正向反饋' };
        if (voluntary >= 70) return { grade: '高度自願-害羞', description: '害羞但允許 + 輕微緊張' };
        if (voluntary >= 60) return { grade: '矛盾-逐漸接受', description: '初始抗拒→逐漸接受' };
        if (voluntary >= 50) return { grade: '矛盾-明顯猶豫', description: '明顯猶豫 + 內心掙扎' };
        if (voluntary >= 40) return { grade: '矛盾-持續輕拒', description: '持續輕拒 + 不情願' };
        if (voluntary >= 30) return { grade: '非自願-忍耐', description: '被動承受 + 事後懊悔' };
        if (voluntary >= 20) return { grade: '非自願-無力反抗', description: '持續抗拒但漸弱' };
        if (voluntary >= 10) return { grade: '非自願-被迫接受', description: '恐懼服從 + 無奈' };
        return { grade: '非自願-激烈反抗', description: '激烈抗拒 + 創傷反應' };
    }

    function getCorruptionStage(forcedCount, affectionLevel) {
        var adj = forcedCount;
        if (affectionLevel >= 16) adj += 3;
        else if (affectionLevel >= 13) adj += 2;
        else if (affectionLevel >= 10) adj += 1;
        
        for (var stage in SEXUAL_CONFIG.CORRUPTION_STAGES) {
            var cfg = SEXUAL_CONFIG.CORRUPTION_STAGES[stage];
            if (adj >= cfg.minCount && adj <= cfg.maxCount) {
                return { stage: parseInt(stage), name: cfg.name };
            }
        }
        return { stage: 4, name: '開始沉淪' };
    }

    function calculateAffectionChange(voluntary, affectionLevel, interactionType, specialStatus, isSuccess) {
        var expChange = 0, levelChange = 0, newStatus = specialStatus, trauma = '';
        
        if (!isSuccess) {
            if (voluntary < 30) {
                return { expChange: -999, levelChange: -1, newSpecialStatus: specialStatus, traumaMark: '嚴重創傷' };
            }
            return { expChange: 0, levelChange: 0, newSpecialStatus: specialStatus, traumaMark: '' };
        }
        
        var stage = getAffectionStageForSex(affectionLevel);
        var isForced = (interactionType === '強制欺騙' && voluntary < 40);
        
        if (voluntary >= 70) {
            expChange = Math.min(100, 30 + Math.floor(voluntary / 2));
        } else if (voluntary >= 40) {
            if (voluntary > 50) expChange = Math.min(50, Math.floor((voluntary - 50) * 5));
            else if (voluntary < 50) expChange = Math.max(-20, Math.floor((voluntary - 50) * 4));
        }
        
        if (voluntary < 40 && isForced) {
            expChange = 0;
            if (stage === '初階期') {
                levelChange = -1;
                trauma = '關係動搖';
            } else if (stage === '中階期') {
                levelChange = 0;
                trauma = '關係動搖';
            } else if (stage === '高階期') {
                expChange = -999;
                newStatus = '自責傾向';
                trauma = '自責傾向觸發';
            } else if (stage === '頂階初') {
                expChange = 40;
                newStatus = '扭曲依賴';
                trauma = '扭曲依賴觸發';
            } else if (stage === '頂階中') {
                expChange = 100;
                if (Math.random() < 0.1) levelChange = 1;
                newStatus = '徹底沉淪';
                trauma = '徹底沉淪觸發';
            } else if (stage === '頂階頂') {
                expChange = 150;
                levelChange = 1;
                newStatus = '共犯';
                trauma = '共犯覺醒觸發';
            }
        }
        
        return {
            expChange: expChange,
            levelChange: levelChange,
            newSpecialStatus: newStatus,
            traumaMark: trauma
        };
    }

    function processSexualInteraction(vars, data) {
        var name = data.characterName;
        var base = '同伴.' + name;
        var affection = v(get(vars, base + '.技能.好感(對阿彬).等級'), 1);
        var affectionExp = v(get(vars, base + '.技能.好感(對阿彬).當前經驗'), 0);
        var forced = v(get(vars, base + '.淪陷.強制次數'), 0);
        var special = get(vars, base + '.淪陷.特殊狀態') || '';
        
        var voluntary = calculateVoluntary(
            affection,
            data.interactionType || '情感推進',
            data.statusEffects || [],
            data.comfort || 50,
            data.isSudden || false,
            special.indexOf('關係動搖') !== -1 || special.indexOf('嚴重創傷') !== -1,
            special
        );
        
        if (special === '徹底沉淪' && data.interactionType === '強制欺騙') {
            voluntary = calculateVoluntary(affection, '情感推進', data.statusEffects || [], data.comfort || 50, data.isSudden || false, false, special);
        }
        
        var grade = getResultGrade(voluntary);
        var forcedInc = false;
        
        if (data.interactionType === '強制欺騙' && voluntary < 30 && special !== '徹底沉淪') {
            forced++;
            forcedInc = true;
        }
        
        var newCorruption = getCorruptionStage(forced, affection);
        var change = calculateAffectionChange(voluntary, affection, data.interactionType || '情感推進', special, data.isSuccess !== false);
        
        var newExp = affectionExp + change.expChange;
        var newLevel = affection + change.levelChange;
        
        if (change.expChange === -999) newExp = 0;
        newLevel = Math.max(1, newLevel);
        
        if (newExp !== affectionExp) set(vars, base + '.技能.好感(對阿彬).當前經驗', newExp);
        if (newLevel !== affection) set(vars, base + '.技能.好感(對阿彬).等級', newLevel);
        if (forcedInc) set(vars, base + '.淪陷.強制次數', forced);
        if (newCorruption.stage !== get(vars, base + '.淪陷.當前階段', 0)) {
            set(vars, base + '.淪陷.當前階段', newCorruption.stage);
        }
        if (change.newSpecialStatus !== special) {
            set(vars, base + '.淪陷.特殊狀態', change.newSpecialStatus);
        }
        
        var result = {
            角色: name,
            完成: data.isSuccess !== false ? true : false,  // 改為「完成」
            內射: data.isInternalEjaculation === true,
            避孕措施: data.避孕措施 || '無',
            類型: data.interactionType || '情感推進',
            自願度: voluntary,
            自願分級: grade.grade,
            淪陷階段: {
                階段: newCorruption.stage,
                名稱: newCorruption.name
            },
            關係變化: {
                經驗變化: change.expChange,
                等級變化: change.levelChange
            },
            特殊狀態: change.newSpecialStatus || '無',
            描寫建議: grade.description
