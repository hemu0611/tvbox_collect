    // ==================== 擴充輔助函數 ====================
    function rollDice(formula) {
        if (!formula || typeof formula !== 'string') return 0;
        var m = formula.match(/^(\d+)d(\d+)$/);
        if (!m) { var n = parseInt(formula); return isNaN(n) ? 0 : n; }
        var count = parseInt(m[1]), sides = parseInt(m[2]);
        if (count <= 0 || sides <= 0) return 0;
        var total = 0;
        for (var i = 0; i < count; i++) total += Math.floor(Math.random() * sides) + 1;
        return total;
    }

    function generateRandomGender() {
        return Math.random() < LIVESTOCK_CONFIG.BREEDING_CONFIG.GENDER_RATIO.male ? '雄性' : '雌性';
    }

    function getAffectionStageForSex(level) {
        var stage = AFFECTION_SYSTEM.getStage(level);
        var map = {
            '陌生': '初階期',
            '朋友-穩定期': '初階期',
            '朋友-親密臨界區': '初階期',
            '摯友-深度期': '中階期',
            '摯友-戀人臨界區': '中階期',
            '戀人-新晉期': '高階期',
            '戀人-穩定臨界區': '高階期',
            '摯愛': '頂階頂'
        };
        return map[stage.name] || '初階期';
    }

    function getSeasonGrowthBonus(season) {
        return SEASON_GROWTH_BONUS[season] || 0;
    }

    function extractCropBonusFromObject(obj) {
        if (!obj || typeof obj !== 'object') return 0;
        var bonus = Number(obj['作物加成']);
        return (!isNaN(bonus) && bonus > 0) ? bonus : 0;
    }

    function extractCropBonusFromCarriedItems(items) {
        if (!_.isPlainObject(items)) return 0;
        var total = 0;
        for (var name in items) {
            if (name.startsWith('$')) continue;
            total += extractCropBonusFromObject(items[name]);
        }
        return total;
    }

    function calculateActualGrowthDays(vars, cropName, baseDays) {
        var totalBonus = 0;
        var season = get(vars, '環境.季節');
        totalBonus += getSeasonGrowthBonus(season);
        
        var crops = get(vars, '作物');
        if (_.isPlainObject(crops)) {
            for (var name in crops) {
                if (name.startsWith('$') || name === cropName) continue;
                totalBonus += extractCropBonusFromObject(crops[name]);
            }
        }
        
        var companions = get(vars, '同伴');
        if (_.isPlainObject(companions)) {
            for (var name in companions) {
                if (name.startsWith('$')) continue;
                totalBonus += extractCropBonusFromCarriedItems(get(companions[name], '攜帶物品'));
            }
        }
        
        if (totalBonus <= 0) return baseDays;
        if (totalBonus <= 50) return Math.max(1, baseDays - Math.floor(baseDays * (totalBonus / 100)));
        return Math.max(1, Math.floor(baseDays / (1 + totalBonus / 100)));
    }

    function calculateGrowthStage(cropData, currentDay, actualDays) {
        var planted = v(cropData.種植日期, 0);
        var growthCycle = v(cropData.成長週期, 0);
        var hasBonus = extractCropBonusFromObject(cropData) > 0;
        if (growthCycle < 0 || hasBonus) return '特殊作物';
        var progress = Math.min(100, Math.round(((currentDay - planted) / actualDays) * 100));
        if (progress < 30) return '幼苗期';
        if (progress < 60) return '生長期';
        if (progress < 100) return '熟成期';
        return '可收割';
    }

    function calculateLivestockGrowthStage(data) {
        var age = v(data.年齡, 12);
        age = Math.max(12, age);
        for (var stage in LIVESTOCK_CONFIG.GROWTH_STAGES) {
            var cfg = LIVESTOCK_CONFIG.GROWTH_STAGES[stage];
            if (age >= cfg.minAge && age < cfg.maxAge) return stage;
        }
        return '成年期';
    }

    function calculateActualProductionCycle(vars, animalName, baseCycle) {
        var totalBonus = 0;
        var season = get(vars, '環境.季節');
        totalBonus += LIVESTOCK_CONFIG.SEASON_PRODUCTION_BONUS[season] || 0;
        
        var facilities = get(vars, '營地.設施');
        if (_.isPlainObject(facilities)) {
            for (var name in facilities) {
                if (name.startsWith('$')) continue;
                var bonus = Number(facilities[name].畜牧加成);
                if (!isNaN(bonus) && bonus > 0) totalBonus += bonus;
            }
        }
        
        if (totalBonus <= 0) return baseCycle;
        var reduction = Math.min(totalBonus / 100, 0.5);
        return Math.max(1, Math.floor(baseCycle * (1 - reduction)));
    }

    // ==================== 作物與畜牧保護系統 ====================
    var PROTECTED_CROP_HARVEST_ACTIONS = ['RESET'];
    var CROP_REQUIRED_FIELDS = ['種植日期', '收成日期', '生長階段', '成長週期'];

    function isSustainableCrop(cropData) {
        return cropData && cropData.harvestAction && 
               PROTECTED_CROP_HARVEST_ACTIONS.indexOf(cropData.harvestAction) !== -1;
    }

    function fixCropData(vars, cropName, cropData, currentDay) {
        var changed = false;
        var growthCycle = cropData.成長週期 || 30;
        var fixedData = {};
        
        for (var i = 0; i < CROP_REQUIRED_FIELDS.length; i++) {
            var field = CROP_REQUIRED_FIELDS[i];
            var value = cropData[field];
            if (value === undefined || value === null) {
                switch(field) {
                    case '種植日期':
                        fixedData[field] = currentDay;
                        logChange('作物修復', cropName + ' 種植日期設為 ' + currentDay);
                        break;
                    case '收成日期':
                        fixedData[field] = currentDay + growthCycle;
                        logChange('作物修復', cropName + ' 收成日期設為 ' + (currentDay + growthCycle));
                        break;
                    case '生長階段':
                        fixedData[field] = '幼苗期';
                        logChange('作物修復', cropName + ' 生長階段設為 幼苗期');
                        break;
                    case '成長週期':
                        fixedData[field] = growthCycle;
                        logChange('作物修復', cropName + ' 成長週期設為 ' + growthCycle);
                        break;
                }
                changed = true;
            }
        }
        
        if (!cropData.harvestAction || PROTECTED_CROP_HARVEST_ACTIONS.indexOf(cropData.harvestAction) === -1) {
            if (isSustainableCrop(cropData) || cropData.harvestAction === 'RESET') {
                fixedData.harvestAction = 'RESET';
                logChange('作物修復', cropName + ' harvestAction 設為 RESET');
                changed = true;
            }
        }
        
        if (changed) {
            for (var key in fixedData) {
                set(vars, '作物.' + cropName + '.' + key, fixedData[key]);
            }
            fixCount++;
            return true;
        }
        return false;
    }

    function checkAndRestoreSustainableCrops(vars, oldVars) {
        if (!oldVars) return false;
        var changed = false;
        var oldCrops = get(oldVars, '作物') || {};
        var currentCrops = get(vars, '作物') || {};
        var currentDay = v(get(vars, '系統.經過天數'), 0);
        
        for (var name in oldCrops) {
            if (name.startsWith('$')) continue;
            var oldCrop = oldCrops[name];
            if (isSustainableCrop(oldCrop) && !currentCrops[name]) {
                keyLog('🌱 檢測到永續作物被刪除: ' + name + '，正在恢復...');
                var growthCycle = oldCrop.成長週期 || 30;
                var restored = {
                    種植日期: currentDay,
                    收成日期: currentDay + growthCycle,
                    生長階段: '幼苗期',
                    harvestAction: 'RESET',
                    成長週期: growthCycle,
                    收穫次數: (oldCrop.收穫次數 || 0) + 1
                };
                set(vars, '作物.' + name, restored);
                logChange('作物恢復', name + ' 已恢復，收成次數 +1');
                changed = true;
                fixCount++;
            }
        }
        return changed;
    }

    function verifyAndFixAllCrops(vars) {
        var changed = false;
        var crops = get(vars, '作物');
        if (!_.isPlainObject(crops)) return false;
        var currentDay = v(get(vars, '系統.經過天數'), 0);
        
        for (var name in crops) {
            if (name.startsWith('$')) continue;
            var crop = crops[name];
            if (!_.isPlainObject(crop)) continue;
            if (fixCropData(vars, name, crop, currentDay)) changed = true;
            if (crop.種植日期 && crop.收成日期 && crop.種植日期 > crop.收成日期) {
                var growthCycle = crop.成長週期 || 30;
                var newHarvest = crop.種植日期 + growthCycle;
                set(vars, '作物.' + name + '.收成日期', newHarvest);
                logChange('作物修復', name + ' 收成日期已修正 ' + crop.收成日期 + ' → ' + newHarvest);
                changed = true;
                fixCount++;
            }
            if (crop.種植日期 > currentDay) {
                set(vars, '作物.' + name + '.種植日期', currentDay);
                logChange('作物修復', name + ' 種植日期不能大於當前天數，設為 ' + currentDay);
                changed = true;
                fixCount++;
            }
        }
        if (changed) debugLog('作物驗證修復完成');
        return changed;
    }

    var LIVESTOCK_REQUIRED_FIELDS = ['年齡', '飼養數量', '生長階段', '飼養開始日'];

    function fixLivestockData(vars, animalName, animalData, currentDay) {
        var changed = false;
        for (var i = 0; i < LIVESTOCK_REQUIRED_FIELDS.length; i++) {
            var field = LIVESTOCK_REQUIRED_FIELDS[i];
            var value = animalData[field];
            if (value === undefined || value === null) {
                switch(field) {
                    case '年齡':
                        set(vars, '畜牧.' + animalName + '.年齡', 12);
                        logChange('畜牧修復', animalName + ' 年齡設為 12');
                        changed = true;
                        break;
                    case '飼養數量':
                        set(vars, '畜牧.' + animalName + '.飼養數量', { 雄性: 1, 雌性: 1 });
                        logChange('畜牧修復', animalName + ' 飼養數量設為 雄:1, 雌:1');
                        changed = true;
                        break;
                    case '生長階段':
                        set(vars, '畜牧.' + animalName + '.生長階段', '成年期');
                        logChange('畜牧修復', animalName + ' 生長階段設為 成年期');
                        changed = true;
                        break;
                    case '飼養開始日':
                        set(vars, '畜牧.' + animalName + '.飼養開始日', currentDay - 12);
                        logChange('畜牧修復', animalName + ' 飼養開始日設為 ' + (currentDay - 12));
                        changed = true;
                        break;
                }
            }
        }
        
        var livestock = get(vars, '畜牧');
        var animal = livestock[animalName];
        if (animal && animal.飼養數量) {
            var males = v(animal.飼養數量.雄性, 0);
            var females = v(animal.飼養數量.雌性, 0);
            if (males < 0 || females < 0) {
                set(vars, '畜牧.' + animalName + '.飼養數量.雄性', Math.max(0, males));
                set(vars, '畜牧.' + animalName + '.飼養數量.雌性', Math.max(0, females));
                logChange('畜牧修復', animalName + ' 數量修正為非負值 雄:' + Math.max(0, males) + ', 雌:' + Math.max(0, females));
                changed = true;
            }
        }
        
        var startDay = v(animalData.飼養開始日, currentDay - 12);
        if (startDay > currentDay) {
            set(vars, '畜牧.' + animalName + '.飼養開始日', currentDay - 12);
            logChange('畜牧修復', animalName + ' 飼養開始日修正 ' + startDay + ' → ' + (currentDay - 12));
            changed = true;
        }
        
        var calculatedAge = Math.max(12, 12 + Math.floor((currentDay - startDay) / 30));
        var currentAge = v(animalData.年齡, calculatedAge);
        if (Math.abs(currentAge - calculatedAge) > 6) {
            set(vars, '畜牧.' + animalName + '.年齡', calculatedAge);
            logChange('畜牧修復', animalName + ' 年齡修正 ' + currentAge + ' → ' + calculatedAge);
            changed = true;
        }
        
        var expectedStage = calculateLivestockGrowthStage({ 年齡: calculatedAge });
        var currentStage = animalData.生長階段;
        if (currentStage && expectedStage && currentStage !== expectedStage) {
            set(vars, '畜牧.' + animalName + '.生長階段', expectedStage);
            logChange('畜牧修復', animalName + ' 生長階段修正 ' + currentStage + ' → ' + expectedStage);
            changed = true;
        }
        
        if (animalData.產出物 && animalData.產出物.週期) {
            var cycle = v(animalData.產出物.週期, 7);
            if (cycle <= 0) {
                set(vars, '畜牧.' + animalName + '.產出物.週期', 7);
                logChange('畜牧修復', animalName + ' 產出週期修正為 7');
                changed = true;
            }
        }
        
        if (changed) fixCount++;
        return changed;
    }

    function verifyAndFixAllLivestock(vars) {
        var changed = false;
        var livestock = get(vars, '畜牧');
        if (!_.isPlainObject(livestock)) return false;
        var currentDay = v(get(vars, '系統.經過天數'), 0);
        for (var name in livestock) {
            if (name.startsWith('$')) continue;
            var animal = livestock[name];
            if (!_.isPlainObject(animal)) continue;
            if (fixLivestockData(vars, name, animal, currentDay)) changed = true;
        }
        if (changed) debugLog('畜牧驗證修復完成');
        return changed;
    }

// ==================== 新生兒生成系統（修改版：放在子嗣下） ====================
function generateNewborn(vars, motherName, motherPath) {
    var litter = 1;
    var dice = Math.floor(Math.random() * 100) + 1;
    if (dice <= 10) {
        litter = 2;
        keyLog('👶👶 驚喜！' + motherName + ' 生下了雙胞胎！');
    } else {
        keyLog('👶 ' + motherName + ' 生下了1個寶寶');
    }
    
    // ✅ 修改：使用「子嗣」而非「同伴」
    var children = get(vars, '子嗣');
    if (!_.isPlainObject(children)) {
        children = {};
        set(vars, '子嗣', children);
    }
    
    var birthCount = get(vars, motherPath + '.生育次數') || 0;
    set(vars, motherPath + '.生育次數', birthCount + litter);
    
    for (var i = 0; i < litter; i++) {
        var gender = Math.random() < 0.5 ? '女' : '男';
        
        // 計算現有子女數量（只計算同一個母親的孩子）
        var existingChildren = 0;
        for (var name in children) {
            if (name.startsWith('$')) continue;
            var data = children[name];
            if (data && data.母親 === motherName) existingChildren++;
        }
        var childNumber = existingChildren + i + 1;
        var childName = motherName + '的孩子' + childNumber;
        
        var finalName = childName;
        var counter = 1;
        while (children[finalName]) finalName = childName + '_' + counter++;
        
        var newborn = {
            人物背景: motherName + ' 的孩子',
            健康度: 80,
            水分值: 100,
            飽腹感: 100,
            疲勞度: 0,
            排泄欲: 0,
            狀態: '新生兒',
            關係: '子女',
            屬性: {},
            技能: {},
            天賦特性: {},
            裝備: {
                頭部: {}, 頸部: {}, 胸部: {}, 其他: {}, 背部: {},
                左手: {}, 右手: {}, 腰部: {}, 腿部: {}, 腳部: {}
            },
            攜帶物品: {},
            劇情演出: [],
            敏感部位: {},
            淪陷: { 強制次數: 0, 當前階段: 0, 抵抗值: 100, 順從值: 0 },
            心理狀態: { 當前所想: '' },
            性癖好: [],
            性愛人設: '',
            重要經歷: {},
            罪惡感: {},
            生育次數: 0,
            母親: motherName,
            父親: get(vars, motherPath + '.生理狀態.授精者') || '未知'  // ✅ 新增：記錄父親
        };
        
        if (gender === '女') {
            newborn.服裝 = { 上衣: '', 下裝: '', 內衣: '', 內褲: '', 鞋子: '', 絲襪: '' };
            newborn.身體特徵 = { 類型: 'female', 體型: '嬰兒型', 三圍: {}, 乳房: {}, 私處: {} };
            newborn.性經驗 = { 性交經驗: '無', 口交經驗: '無', 肛交經驗: '無', 性行為次數: 0, 性伴侶數量: 0, 處女: '是' };
            newborn.生理狀態 = { 陰蒂狀態: '正常', 子宮狀態: '正常', 月經週期: 1, 懷孕狀態: '未懷孕', 懷孕天數: 0 };
            newborn.性別 = '女';
        } else {
            newborn.服裝 = { 上衣: '', 下裝: '', 內衣: '', 內褲: '', 鞋子: '', 襪子: '' };
            newborn.身體特徵 = { 類型: 'male', 陰莖: { 長度: 0, 粗度: 0, 類型: '', 充血程度: '' } };
            newborn.性經驗 = { 性交經驗: '無', 口交經驗: '無', 肛交經驗: '無', 性行為次數: 0, 性伴侶數量: 0, 處男: '是' };
            newborn.生理狀態 = { 勃起狀態: '未勃起', 射精狀態: '未射精' };
            newborn.性別 = '男';
        }
        
        // ✅ 修改：寫入「子嗣」而非「同伴」
        set(vars, '子嗣.' + finalName, newborn);
        logChange('新生兒', motherName + ' 生下 ' + finalName + ' (' + gender + ')');
    }
    keyLog('👶 ' + motherName + ' 共生下 ' + litter + ' 個寶寶');
    return litter;
}

    // ======================== 路徑確保 ========================
    function ensurePaths(vars) {
        // 強制刪除已廢棄的狀態.飽腹感
if (get(vars, '狀態.飽腹感') !== undefined) {
    _.unset(vars, '狀態.飽腹感');
    console.log('🗑️ 已刪除廢棄路徑: 狀態.飽腹感');
}
        if (!_.isPlainObject(get(vars, '任務'))) {
            set(vars, '任務', { 主線: {}, 支線: {}, 日常: {}, 緊急: {}, 羈絆: {} });
        }
        
        var comps = get(vars, '同伴');
        if (_.isPlainObject(comps)) {
